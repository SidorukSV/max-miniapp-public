Функция бит_омни_ДанныеСправочника(Запрос) Экспорт

	ТипПоиска = Запрос.ПараметрыЗапроса.Получить("search_type");
	
	Если ТипПоиска = Неопределено Тогда
		Возврат бит_омни_ВсеСотрудники();	
	ИначеЕсли ТипПоиска = "BySpec" Тогда
		ИдентификаторСпециализации = Запрос.ПараметрыЗапроса.Получить("specializationId");
		Возврат бит_омни_СотрудникиПоСпециализации(ИдентификаторСпециализации);
	ИначеЕсли ТипПоиска = "ByID" Тогда
		Идентификатор = Запрос.ПараметрыЗапроса.Получить("doctorId");
		Возврат бит_омни_СотрудникПоUUID(Идентификатор);
	Иначе	
		Возврат бит_омни_ИнтеграцияСерверСлужебный.НеверныйТипПоиска();	
	КонецЕсли;

КонецФункции

Функция бит_омни_ВсеСотрудники()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Сотрудники.Ссылка)) КАК doctorId,
	|	Сотрудники.Фамилия + "" "" + Сотрудники.Имя + "" "" + Сотрудники.Отчество КАК doctorTitle,
	|	Сотрудники.Фамилия КАК doctorLastname,
	|	Сотрудники.Имя КАК doctorFirstname,
	|	Сотрудники.Отчество КАК doctorPatronymic
	|ИЗ
	|	Справочник.Сотрудники КАК Сотрудники
	|ГДЕ
	|	НЕ Сотрудники.ПометкаУдаления
	|	И Сотрудники.УчаствуетВКалендарномПланировании
	|	И НЕ Сотрудники.ЭтоГруппа
	|
	|УПОРЯДОЧИТЬ ПО
	|	doctorTitle";
	
	РезультатЗапроса = Запрос.Выполнить();
	ДанныеЗапроса = РезультатЗапроса.Выгрузить();
	
	ТелоОтвета = ОбщегоНазначения.ТаблицаЗначенийВМассив(ДанныеЗапроса);
	Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(ТелоОтвета);

	
КонецФункции

Функция бит_омни_СотрудникиПоСпециализации(Знач ИдентификаторСпециализации)

	Специализация = Справочники.КатегорииВыработки.бит_омни_СпециализацияПоUUID(ИдентификаторСпециализации, Истина);
	
	Если ТипЗнч(Специализация) <> Тип("СправочникСсылка.КатегорииВыработки") Тогда
		Возврат Специализация; // если тип другой, то это HTTPСервисОтвет
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СотрудникиСпециализации.Ссылка КАК Сотрудник
	|ПОМЕСТИТЬ СотрудникиПоСпециализации
	|ИЗ
	|	Справочник.Сотрудники.Специализации КАК СотрудникиСпециализации
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	|		ПО СотрудникиСпециализации.Ссылка = Сотрудники.Ссылка
	|ГДЕ
	|	СотрудникиСпециализации.Специализация = &Специализация
	|	И НЕ Сотрудники.ПометкаУдаления
	|	И НЕ Сотрудники.Архив
	|	И Сотрудники.УчаствуетВКалендарномПланировании
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ГрафикиРаботы.Сотрудник КАК Сотрудник,
	|	ГрафикиРаботы.Филиал КАК Филиал
	|ПОМЕСТИТЬ СотрудникиСГрафикамиНаМесяцВперед
	|ИЗ
	|	РегистрСведений.ГрафикиРаботы КАК ГрафикиРаботы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СотрудникиПоСпециализации КАК СотрудникиПоСпециализации
	|		ПО ГрафикиРаботы.Сотрудник = СотрудникиПоСпециализации.Сотрудник
	|ГДЕ
	|	ГрафикиРаботы.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СотрудникиСГрафикамиНаМесяцВперед.Сотрудник)) КАК doctorId,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СотрудникиСГрафикамиНаМесяцВперед.Сотрудник) КАК doctorTitle,
	|	Сотрудники.Фамилия КАК doctorLastname,
	|	Сотрудники.Имя КАК doctorFirstname,
	|	Сотрудники.Отчество КАК doctorPatronymic,                                                     
	|	РАЗНОСТЬДАТ(ДАТАВРЕМЯ(1,1,1), Сотрудники.ДлительностьПриема, МИНУТА) КАК doctorDuration,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СотрудникиСГрафикамиНаМесяцВперед.Филиал)) КАК branchId,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СотрудникиСГрафикамиНаМесяцВперед.Филиал) КАК branchTitle
	|ИЗ
	|	СотрудникиСГрафикамиНаМесяцВперед КАК СотрудникиСГрафикамиНаМесяцВперед
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	|		ПО СотрудникиСГрафикамиНаМесяцВперед.Сотрудник = Сотрудники.Ссылка";
	
	Сегодня = НачалоДня(ТекущаяДата());
	Запрос.УстановитьПараметр("Специализация", Специализация);
	Запрос.УстановитьПараметр("ДатаНачала", Сегодня);
	Запрос.УстановитьПараметр("ДатаОкончания", ДобавитьМесяц(Сегодня, 1));
	
	РезультатЗапроса = Запрос.Выполнить();
	ДанныеЗапроса = РезультатЗапроса.Выгрузить();
	
	ТелоОтвета = ОбщегоНазначения.ТаблицаЗначенийВМассив(ДанныеЗапроса);
	Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(ТелоОтвета);
	
КонецФункции

Функция бит_омни_СотрудникПоUUID(Знач Идентификатор, ВернутьСсылку = Ложь) Экспорт

	РезультатПроверки = бит_омни_ИнтеграцияСервер.ВалидироватьИдентификатор(Идентификатор, "doctorId");
	
	Если РезультатПроверки <> Неопределено Тогда
		Возврат РезультатПроверки;
	КонецЕсли;
	
	Сотрудник = ПолучитьСсылку(Идентификатор);
	Если НЕ ОбщегоНазначения.СсылкаСуществует(Сотрудник) Тогда
		Возврат бит_омни_НеНайденСотрудник();
	КонецЕсли;
	
	Если ВернутьСсылку Тогда
		Возврат Сотрудник;
	КонецЕсли;
	
	Реквизиты = Новый Структура("doctorId, doctorTitle, doctorLastname, doctorFirstname, doctorPatronymic", "ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Ссылка))", "Наименование", "Фамилия", "Имя", "Отчество"); 
	ТелоОтвета = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Сотрудник, Реквизиты, Истина);
	
	Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(ТелоОтвета);

КонецФункции

Функция бит_омни_НеНайденСотрудник()

	Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой("employee_not_found", 404);	

КонецФункции



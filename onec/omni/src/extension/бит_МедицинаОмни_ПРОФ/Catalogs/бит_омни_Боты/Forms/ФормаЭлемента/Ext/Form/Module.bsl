
&НаКлиенте
Процедура ЗаполнитьИнформациюОБоте(Команда)
	ЗаполнитьИнформациюОБотеНаСервере();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИнформациюОБотеНаСервере()
	
	Если Объект.Канал = Перечисления.бит_омни_КаналыСвязи.MAX Тогда
		ДанныеБота = бит_омни_ИнтеграцияСMAX.ИнформацияОБоте(Объект.Токен);
		Если ДанныеБота = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		Объект.Идентификатор = Формат(ДанныеБота.user_id, "ЧГ=0");
		Объект.Наименование = Лев(ПредставлениеБотаMAX(ДанныеБота), 150);
		Объект.ИмяПользователя = ИмяПользователяБотаMAX(ДанныеБота);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПредставлениеБотаMAX(ДанныеБота)
	
	Представление = "";
	Если ДанныеБота.Свойство("name", Представление) И ЗначениеЗаполнено(Представление) Тогда
		Возврат СокрЛП(Представление);
	КонецЕсли;
	
	Если ДанныеБота.Свойство("first_name", Представление) И ЗначениеЗаполнено(Представление) Тогда
		Возврат СокрЛП(Представление);
	КонецЕсли;
	
	Возврат ИмяПользователяБотаMAX(ДанныеБота);
	
КонецФункции

&НаСервереБезКонтекста
Функция ИмяПользователяБотаMAX(ДанныеБота)
	
	ИмяПользователя = "";
	Если ДанныеБота.Свойство("username", ИмяПользователя) Тогда
		Возврат СокрЛП(ИмяПользователя);
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

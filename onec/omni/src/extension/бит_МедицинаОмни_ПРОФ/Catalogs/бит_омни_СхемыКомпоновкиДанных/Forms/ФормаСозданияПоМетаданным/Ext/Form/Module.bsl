#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	АдресСхемыКомпоновки = "";
	ОбновитьТолькоНаборы = Ложь;
	
	Параметры.Свойство("АдресСхемыКомпоновки", АдресСхемыКомпоновки);
	Параметры.Свойство("ОбновитьТолькоНаборы", ОбновитьТолькоНаборы);
	
	ТекущийШаг = 1;
	ЗаполнитьДеревоМетаданных();
	ОчиститьРеквизиты();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Далее(Команда)
	
	ТекущиеДанные = Элементы.ОбъектыМетаданных.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено
		Или ТекущиеДанные.ЭтоГруппа Тогда
		Сообщить(НСтр("ru='Выберите справочник или документ.'"));
		Возврат;
	КонецЕсли;
	
	ПолноеИмяМетаданных = ТекущиеДанные.ПолноеИмя;
	ЗаполнитьРеквизитыВыбранногоОбъекта(ПолноеИмяМетаданных);
	
	ТекущийШаг = 2;
	УстановитьВидимостьШагов();
	
КонецПроцедуры

&НаКлиенте
Процедура Назад(Команда)
	
	ТекущийШаг = 1;
	УстановитьВидимостьШагов();
	
КонецПроцедуры

&НаКлиенте
Процедура Создать(Команда)
	
	АдресСформированнойСхемы = СформироватьСхемуНаСервере();
	Если Не ЗначениеЗаполнено(АдресСформированнойСхемы) Тогда
		Сообщить(НСтр("ru='Отметьте хотя бы один реквизит.'"));
		Возврат;
	КонецЕсли;
	
	ОповеститьОВыборе(АдресСформированнойСхемы);
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	
	Закрыть();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьДеревоМетаданных()
	
	ОбъектыМетаданныхДерево = РеквизитФормыВЗначение("ОбъектыМетаданных");
	
	ГруппаСправочники = ОбъектыМетаданныхДерево.Строки.Добавить();
	ГруппаСправочники.Представление = НСтр("ru='Справочники'");
	ГруппаСправочники.ЭтоГруппа = Истина;
	
	Для Каждого МетаданныеСправочника Из Метаданные.Справочники Цикл
		НоваяСтрока = ГруппаСправочники.Строки.Добавить();
		ЗаполнитьСтрокуМетаданных(НоваяСтрока, МетаданныеСправочника);
	КонецЦикла;
	
	ГруппаДокументы = ОбъектыМетаданныхДерево.Строки.Добавить();
	ГруппаДокументы.Представление = НСтр("ru='Документы'");
	ГруппаДокументы.ЭтоГруппа = Истина;
	
	Для Каждого МетаданныеДокумента Из Метаданные.Документы Цикл
		НоваяСтрока = ГруппаДокументы.Строки.Добавить();
		ЗаполнитьСтрокуМетаданных(НоваяСтрока, МетаданныеДокумента);
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(ОбъектыМетаданныхДерево, "ОбъектыМетаданных");
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСтрокуМетаданных(СтрокаДерева, МетаданныеОбъекта)
	
	СтрокаДерева.Представление = ?(ЗначениеЗаполнено(МетаданныеОбъекта.Синоним), Строка(МетаданныеОбъекта.Синоним), МетаданныеОбъекта.Имя);
	СтрокаДерева.ПолноеИмя = МетаданныеОбъекта.ПолноеИмя();
	СтрокаДерева.ЭтоГруппа = Ложь;
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьРеквизиты()
	
	РеквизитыПередЗаписью.Очистить();
	РеквизитыПриЗаписи.Очистить();;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРеквизитыВыбранногоОбъекта(ПолноеИмяОбъекта)
	
	ТаблицаРеквизитов = бит_омни_СхемыКомпоновки.ТаблицаРеквизитовМетаданных(ПолноеИмяОбъекта);
	РеквизитыПередЗаписью.Загрузить(ТаблицаРеквизитов);
	РеквизитыПриЗаписи.Загрузить(ТаблицаРеквизитов);
	
КонецПроцедуры

&НаСервере
Функция СформироватьСхемуНаСервере()
	
	СхемаИсходная = Неопределено;
	Если ОбновитьТолькоНаборы
		И ЭтоАдресВременногоХранилища(АдресСхемыКомпоновки) Тогда
		СхемаИсходная = ПолучитьИзВременногоХранилища(АдресСхемыКомпоновки);
	КонецЕсли;
	
	СхемаКомпоновки = бит_омни_СхемыКомпоновки.СхемаПоМетаданным(
		ПолноеИмяМетаданных,
		РеквизитыПередЗаписью,
		РеквизитыПриЗаписи,
		СхемаИсходная,
		ОбновитьТолькоНаборы);
	
	Если ТипЗнч(СхемаКомпоновки) <> Тип("СхемаКомпоновкиДанных") Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат ПоместитьВоВременноеХранилище(СхемаКомпоновки);
	
КонецФункции

&НаКлиенте
Процедура УстановитьВидимостьШагов()
	
	ЭтоВыборМетаданных = (ТекущийШаг = 1);
	ЭтоВыборРеквизитов = (ТекущийШаг = 2);
	
	Элементы.ГруппаВыборМетаданных.Видимость = ЭтоВыборМетаданных;
	Элементы.ГруппаРеквизиты.Видимость = ЭтоВыборРеквизитов;
	Элементы.Далее.Видимость = ЭтоВыборМетаданных;
	Элементы.Назад.Видимость = ЭтоВыборРеквизитов;
	Элементы.Создать.Видимость = ЭтоВыборРеквизитов;
	
КонецПроцедуры

#КонецОбласти


#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	СхемаКомпоновки = ТекущийОбъект.ХранилищеСКД.Получить();
	ПоместитьСКДВоВременноеХранилище(СхемаКомпоновки);
	ИнициализироватьКомпоновщикНастроек();
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Объект.Ссылка.Пустая() 
		И ЗначениеЗаполнено(Параметры.ЗначениеКопирования) 
	Тогда
		СхемаКомпоновки = Параметры.ЗначениеКопирования.ХранилищеСКД.Получить();
		ПоместитьСКДВоВременноеХранилище(СхемаКомпоновки);
	КонецЕсли;
	
	ИнициализироватьКомпоновщикНастроек();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
		Если ПоместитьСКДИзАдресаВоВременноеХранилище(ВыбранноеЗначение) Тогда
			ИнициализироватьКомпоновщикНастроек();
			Модифицированность = Истина;
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ВыбранноеЗначение) <> Тип("СхемаКомпоновкиДанных") Тогда
		Возврат;
	КонецЕсли;
	
	ПоместитьСКДВоВременноеХранилище(ВыбранноеЗначение);
	ИнициализироватьКомпоновщикНастроек();
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	СинхронизироватьНастройкиВСхему();
	СхемаКомпоновки = ПолучитьСКДИзВременногоХранилища();
	ТекущийОбъект.ХранилищеСКД = Новый ХранилищеЗначения(СхемаКомпоновки, Новый СжатиеДанных(9));
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура РедактироватьСКД(Команда)
	
	#Если НЕ ТолстыйКлиентУправляемоеПриложение И НЕ ТолстыйКлиентОбычноеПриложение Тогда
		Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = НСтр("ru='Конструктор схемы компоновки работает только в толстом клиенте'");
		Сообщение.Сообщить();
		Возврат;
	#КонецЕсли
	
	#Если ТолстыйКлиентУправляемоеПриложение ИЛИ ТолстыйКлиентОбычноеПриложение Тогда
		СинхронизироватьНастройкиВСхему();
		СхемаКомпоновки = ПолучитьСКДИзВременногоХранилища();
	
		КонструкторСхемы = Новый КонструкторСхемыКомпоновкиДанных;
		КонструкторСхемы.УстановитьСхему(СхемаКомпоновки);
		КонструкторСхемы.Редактировать(ЭтаФорма);
		
		ПоместитьСКДВоВременноеХранилище(СхемаКомпоновки);
		ИнициализироватьКомпоновщикНастроек();
		Модифицированность = Истина;
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьПоМетаданным(Команда)
	
	ОбновитьТолькоНаборы = Ложь;
	Если ТекущаяСхемаНепустая() Тогда
		ТекстВопроса = НСтр("ru='Схема уже содержит наборы данных или настройки. Да - заменить схему, Нет - обновить только наборы ПередЗаписью/ПриЗаписи, Отмена - отменить.'");
		Ответ = Вопрос(ТекстВопроса, РежимДиалогаВопрос.ДаНетОтмена);
		
		Если Ответ = КодВозвратаДиалога.Отмена Тогда
			Возврат;
		ИначеЕсли Ответ = КодВозвратаДиалога.Нет Тогда
			ОбновитьТолькоНаборы = Истина;
		КонецЕсли;
	КонецЕсли;
	
	СинхронизироватьНастройкиВСхему();
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("АдресСхемыКомпоновки", АдресСхемыКомпоновки);
	ПараметрыОткрытия.Вставить("ОбновитьТолькоНаборы", ОбновитьТолькоНаборы);
	
	ОткрытьФорму(
		"Справочник.бит_омни_СхемыКомпоновкиДанных.Форма.ФормаСозданияПоМетаданным",
		ПараметрыОткрытия,
		ЭтаФорма);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПоместитьСКДВоВременноеХранилище(СхемаКомпоновки)
		
	АдресСхемыКомпоновки = ПоместитьВоВременноеХранилище(СхемаКомпоновки, УникальныйИдентификатор);
	
КонецПроцедуры

&НаСервере
Функция ПоместитьСКДИзАдресаВоВременноеХранилище(АдресНовойСхемы)
	
	Если Не ЭтоАдресВременногоХранилища(АдресНовойСхемы) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	СхемаКомпоновки = ПолучитьИзВременногоХранилища(АдресНовойСхемы);
	Если ТипЗнч(СхемаКомпоновки) <> Тип("СхемаКомпоновкиДанных") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПоместитьСКДВоВременноеХранилище(СхемаКомпоновки);
	Возврат Истина;
	
КонецФункции

&НаСервере
Процедура ИнициализироватьКомпоновщикНастроек()
	
	Попытка	
		СхемаКомпоновкиДанных = ПолучитьСКДИзВременногоХранилища();
		
		КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновки));
		КомпоновщикНастроек.ЗагрузитьНастройки(СхемаКомпоновкиДанных.НастройкиПоУмолчанию);
		КомпоновщикНастроек.Восстановить(СпособВосстановленияНастроекКомпоновкиДанных.ПроверятьДоступность);
	Исключение
		КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Процедура СинхронизироватьНастройкиВСхему()
	
	СхемаКомпоновки = ПолучитьСКДИзВременногоХранилища();
	
	Если ТипЗнч(КомпоновщикНастроек) = Тип("КомпоновщикНастроекКомпоновкиДанных") Тогда
		СхемаКомпоновки.ВариантыНастроек.Очистить();
		ВариантНастроекКомпоновки = СхемаКомпоновки.ВариантыНастроек.Добавить();
		ВариантНастроекКомпоновки.Имя = "НастройкиПоУмолчанию";
		ВариантНастроекКомпоновки.Представление = "Настройки по умолчанию";
	КонецЕсли;
	
	ПоместитьСКДВоВременноеХранилище(СхемаКомпоновки);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСКДИзВременногоХранилища()

	СхемаКомпоновки = Неопределено;
	
	Если ЭтоАдресВременногоХранилища(АдресСхемыКомпоновки) Тогда
		СхемаКомпоновки = ПолучитьИзВременногоХранилища(АдресСхемыКомпоновки);
	КонецЕсли;
	
	НужноПоместить = Ложь;	
	
	// Ну а если всё еще нету схемы, значит это с нуля создают схему, просто создадим пустую
	Если ТипЗнч(СхемаКомпоновки) <> Тип("СхемаКомпоновкиДанных") Тогда
		СхемаКомпоновки = Новый СхемаКомпоновкиДанных;
		НужноПоместить = Истина;
	КонецЕсли;                  
	
	Если НужноПоместить Тогда
		ПоместитьСКДВоВременноеХранилище(СхемаКомпоновки);
	КонецЕсли;
	
	Возврат СхемаКомпоновки; 

КонецФункции

&НаСервере
Функция ТекущаяСхемаНепустая()
	
	СхемаКомпоновки = ПолучитьСКДИзВременногоХранилища();
	
	Попытка
		Если СхемаКомпоновки.НаборыДанных.Количество() > 0 Тогда
			Возврат Истина;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Попытка
		Если СхемаКомпоновки.НастройкиПоУмолчанию.Выбор.Элементы.Количество() > 0 Тогда
			Возврат Истина;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
Процедура Предпросмотр(Команда)
	
	Если Объект.Ссылка.Пустая() Тогда
		ЭтаФорма.Записать();
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура("Схема", Объект.Ссылка);
	
	ОткрытьФорму("Справочник.бит_омни_СхемыКомпоновкиДанных.Форма.ФормаПредпросмотр", ПараметрыОткрытия); 
	
КонецПроцедуры

#КонецОбласти







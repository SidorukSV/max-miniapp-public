#Область ПрограммныйИнтерфейс

// Получает менеджер справочника по идентификатору каталога
Функция МенеджерСправочникаПоИдентификаторуКаталога(ИдентификаторКаталога) Экспорт
	Возврат ПолучитьМенеджераПоКлючу("catalog", ИдентификаторКаталога);
КонецФункции

// Получает менеджер документа по идентификатору документа
Функция МенеджерДокументаПоИдентификатору(ИдентификаторДокумента) Экспорт
	Возврат ПолучитьМенеджераПоКлючу("document", ИдентификаторДокумента);
КонецФункции

// Получает менеджер объекта по типу транзакции
Функция МенеджерОбъектаПоТипуТранзакции(ТипТранзакции) Экспорт
	Возврат ПолучитьМенеджераПоКлючу("transaction", ТипТранзакции);
КонецФункции

// Универсальная функция получения менеджера по типу ключа и значению ключа
// Параметры:
//   ТипКлюча - Строка - тип ключа ("catalog", "document", "transaction")
//   Ключ - Строка - значение ключа для поиска
// Возвращаемое значение:
//   Произвольный - менеджер объекта или Неопределено, если ключ не найден
Функция ПолучитьМенеджераПоКлючу(ТипКлюча, Ключ) Экспорт
	
	// Проверка входных параметров
	Если ПустаяСтрока(ТипКлюча) Или ПустаяСтрока(Ключ) Тогда
		ЗаписьЖурналаРегистрации(
			"ОМНИ.Предупреждение",
			УровеньЖурналаРегистрации.Предупреждение,
			,,
			СтрШаблон(НСтр("ru='Получение менеджера с пустым типом ключа или ключом: Тип=%1, Ключ=%2'"), ТипКлюча, Ключ));
		Возврат Неопределено;
	КонецЕсли;
	
	// Получаем дерево соответствий (статическое, инициализируется один раз)
	СтатическоеДеревоМенеджеров = ИнициализироватьДеревоМенеджеров();
	
	// Получаем соответствие для указанного типа ключа
	СоответствиеПоТипу = СтатическоеДеревоМенеджеров.Получить(ТипКлюча);
	Если СоответствиеПоТипу = Неопределено Тогда
		ЗаписьЖурналаРегистрации(
		"ОМНИ.Предупреждение",
		УровеньЖурналаРегистрации.Предупреждение,
		,,
		СтрШаблон("Неизвестный тип ключа: %1", ТипКлюча));
		Возврат Неопределено;
	КонецЕсли;
	
	// Получаем менеджер по конкретному ключу
	Менеджер = СоответствиеПоТипу.Получить(Ключ);
	Если Менеджер = Неопределено Тогда
		ЗаписьЖурналаРегистрации(
		"ОМНИ.Предупреждение",
		УровеньЖурналаРегистрации.Предупреждение,
		,,
		СтрШаблон(НСтр("ru='Менеджер не найден: Тип=%1, Ключ=%2'"), ТипКлюча, Ключ));
	КонецЕсли;
	
	Возврат Менеджер;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Инициализирует дерево соответствий типов ключей и менеджеров
Функция ИнициализироватьДеревоМенеджеров()
	
	// Названия соответствий специально переделаны под синонимы, 
	// чтобы случайно не назвать переменную Справочники, Документы, РегистрыНакопления и т.п.
	// т.к. эти слова зарезервированы в глобальном контексте
	
	ДеревоМенеджеров = Новый Соответствие;
	
	// Соответствие для каталогов (справочников)
	Каталоги = Новый Соответствие;
	Каталоги.Вставить("clients", Справочники.Клиенты);
	Каталоги.Вставить("specializations", Справочники.КатегорииВыработки);
	Каталоги.Вставить("employees", Справочники.Сотрудники);
	Каталоги.Вставить("branches", Справочники.Филиалы);
	Каталоги.Вставить("surveyTemplates", Справочники.ШаблоныАнкет);
	ДеревоМенеджеров.Вставить("catalog", Каталоги);
	
	// Соответствие для хоз. операций (документов)
	ХозяйственныеОперации = Новый Соответствие;
	ХозяйственныеОперации.Вставить("appointments", Документы.Заявка);
	ХозяйственныеОперации.Вставить("schedule", Документы.УстановкаГрафиковРаботы);
	ХозяйственныеОперации.Вставить("medical", Документы.Прием);
	ХозяйственныеОперации.Вставить("surveys", Документы.Анкета);
	ДеревоМенеджеров.Вставить("document", ХозяйственныеОперации);
	
	// Соответствие для транзакций (регистров накоплений)
	Транзакции = Новый Соответствие;
	Транзакции.Вставить("bonus", РегистрыНакопления.НакопленияПоСкидкам);
	ДеревоМенеджеров.Вставить("transaction", Транзакции);
	
	Возврат ДеревоМенеджеров;
	
КонецФункции

#КонецОбласти

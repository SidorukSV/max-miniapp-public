#Область ПрограммныйИнтерфейс

Функция ИнформацияОБоте(Токен) Экспорт

	Соединение = бит_омни_ИнтеграцияСMAXПовтИсп.СоединениеCAPI();
	Заголовки = ЗаголовкиMAX(Токен);

	Запрос = Новый HTTPЗапрос("/me", Заголовки);
	Ответ = Соединение.Получить(Запрос);

	ДанныеОтвета = ПрочитатьОтветMAX(Ответ);
	Если Ответ.КодСостояния <> 200 Тогда
		ОбщегоНазначения.СообщитьПользователю(СтрШаблон("Код ошибки: %1
														|Текст ошибки: %2", Ответ.КодСостояния, ДанныеОтвета.Текст));
		Возврат Неопределено;
	КонецЕсли;

	Возврат ДанныеОтвета.Тело;

КонецФункции

// Отправляет текстовое сообщение через бота в мессенджер MAX с возможностью указания форматирования.
//
// Параметры:
//   ТекстСообщения - Строка - текст отправляемого сообщения
//   Получатель - - получатель сообщения
//     - Массив из СправочникСсылка.бит_омни_Контакты, СправочникСсылка.Сотрудники, СправочникСсылка.Клиенты  
//     - СправочникСсылка.бит_омни_Контакты
//     - СправочникСсылка.Сотрудники
//     - СправочникСсылка.Клиенты
//   Бот - СправочникСсылка.бит_омни_Боты - идентификатор бота, от имени которого отправляется сообщение
//   Формат - Строка - форматирование текста сообщения (например, "markdown", "html")
//           - Неопределено - используется форматирование по умолчанию
//
// Возвращаемое значение:
//   см. бит_омни_ИнтеграцияСMAX.ОтправитьСообщение
Функция ОтправитьТекстовоеСообщение(ТекстСообщения, Получатель, Бот, Формат = Неопределено) Экспорт

	ПараметрыСообщения = Новый Структура("text", ТекстСообщения);

	Если ЗначениеЗаполнено(Формат) Тогда
		ПараметрыСообщения.Вставить("format", Формат);
	КонецЕсли;

	Возврат ОтправитьСообщение(ПараметрыСообщения, Получатель, Бот);

КонецФункции

// Отправляет сообщение через интеграцию с MAX одному или нескольким получателям
//
// Параметры:
//   ПараметрыСообщения - Структура, СправочникСсылка.бит_омни_ШаблоныСообщений - параметры сообщения (зависят от типа сообщения)
//   Получатель - Строка, Массив из Строка - идентификатор получателя или массив получателей
//   Бот - Строка - идентификатор бота
//   Контекст - Структура, Неопределено - дополнительные параметры для отправки сообщения
//
// Возвращаемое значение:
//   см. бит_омни_ИнтеграцияСMAX.ОтправитьСообщениеПолучателю
Функция ОтправитьСообщение(ПараметрыСообщения, Получатель, Бот, Контекст = Неопределено) Экспорт

	ДанныеБота = бит_омни_ИнтеграцияСMAXПовтИсп.ДанныеБота(Бот);
	Если ДанныеБота = Неопределено Тогда
		Возврат Новый Структура("success, message", Ложь, НСтр("ru='Не найден бот MAX'"));
	КонецЕсли;

	Получатели = ПолучателиСообщенияMAX(Получатель);
	Если ТипЗнч(Получатель) = Тип("Массив") Тогда

		РезультатыОтправки = Новый Массив;
		Для Каждого ТекущийПолучатель Из Получатели Цикл
			РезультатыОтправки.Добавить(ОтправитьСообщениеПолучателю(ПараметрыСообщения, ТекущийПолучатель, Бот,
				ДанныеБота, Контекст));
		КонецЦикла;

		Возврат РезультатыОтправки;

	КонецЕсли;

	Если Получатели.Количество() = 0 Тогда
		Возврат Новый Структура("success, message", Ложь, НСтр("ru='Не определен получатель сообщения MAX'"));
	КонецЕсли;

	Возврат ОтправитьСообщениеПолучателю(ПараметрыСообщения, Получатели[0], Бот, ДанныеБота, Контекст);

КонецФункции

Функция ОтправитьСообщениеПолучателю(ПараметрыСообщения, Получатель, Бот, ДанныеБота, Контекст)

	ПолучательСообщения = ПолучательСообщенияMAX(Получатель, Бот);
	Адресат = ПараметрыАдресата(ПолучательСообщения, Бот);
	Если Адресат = Неопределено Тогда
		Возврат Новый Структура("success, message", Ложь, НСтр("ru='Не определен получатель сообщения MAX'"));
	КонецЕсли;

	ПараметрыТекущегоСообщения = ПараметрыСообщенияMAX(ПараметрыСообщения, ПолучательСообщения, Контекст);
	ТелоСообщения = ТелоСообщенияMAX(ПараметрыТекущегоСообщения);
	Если ТелоСообщения = Неопределено Тогда
		Возврат Новый Структура("success, message", Ложь, НСтр("ru='Не заполнен текст или вложения сообщения MAX'"));
	КонецЕсли;

	СтрокаЗапроса = СтруктураВJSON(ТелоСообщения);

	Соединение = бит_омни_ИнтеграцияСMAXПовтИсп.СоединениеCAPI();
	Заголовки = ЗаголовкиMAX(ДанныеБота.Токен);
	Заголовки.Вставить("Content-Type", "application/json");

	Ресурс = СтрШаблон("/messages?%1=%2", Адресат.Параметр, Адресат.Значение);
	Запрос = Новый HTTPЗапрос(Ресурс, Заголовки);
	Запрос.УстановитьТелоИзСтроки(СтрокаЗапроса, КодировкаТекста.UTF8);

	Ответ = Соединение.ОтправитьДляОбработки(Запрос);
	ДанныеОтвета = ПрочитатьОтветMAX(Ответ);

	Если Ответ.КодСостояния < 200 Или Ответ.КодСостояния >= 300 Тогда
		ЗаписьЖурналаРегистрации(
			"ОМНИ.MAX.ОшибкаОтправки", УровеньЖурналаРегистрации.Ошибка, , , СтрШаблон(
			"Код ответа MAX: %1. Тело ответа: %2", Ответ.КодСостояния, ДанныеОтвета.Текст));
	КонецЕсли;

	Возврат ДанныеОтвета.Тело;

КонецФункции

Функция ОбработатьWebhook(HTTPЗапрос, Бот) Экспорт

	Попытка
		Обновление = бит_омни_ИнтеграцияСервер.ТелоЗапросаВСтруктуру(HTTPЗапрос);
		Если ТипЗнч(Обновление) <> Тип("Структура") Тогда
			Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой("invalid_max_update");
		КонецЕсли;

		ОбработатьОбновление(Обновление, Бот);

		Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(Новый Структура("success", Истина));

	Исключение
		ИнфоОшибки = ИнформацияОбОшибке();
		ТекстОшибки = ПодробноеПредставлениеОшибки(ИнфоОшибки);

		ЗаписьЖурналаРегистрации(
			"ОМНИ.MAX.Webhook", УровеньЖурналаРегистрации.Ошибка, , , ТекстОшибки);

		Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой("max_webhook_error", 500, ТекстОшибки);
	КонецПопытки;

КонецФункции

Процедура ОбработатьОбновление(Обновление, Бот) Экспорт

	ТипОбновления = СтроковоеСвойство(Обновление, "update_type");

	Если ТипОбновления = "message_created" Тогда
		ОбработатьСозданиеСообщения(Обновление, Бот);
	ИначеЕсли ТипОбновления = "bot_started" Тогда
		ОбработатьЗапускБота(Обновление, Бот);
	ИначеЕсли ТипОбновления = "bot_stopped" Тогда
		ОбработатьОстановкуБота(Обновление, Бот);
	ИначеЕсли ТипОбновления = "message_callback" Тогда
		ОбработатьCallback(Обновление, Бот);
	Иначе
		ЗаписатьСобытиеВЖурнал(Обновление, Бот, НСтр("ru='Событие MAX пропущено'"));
	КонецЕсли;

КонецПроцедуры

Функция ПолучитьКонтактПоUser(User, Бот) Экспорт

	Если ТипЗнч(User) <> Тип("Структура") Тогда
		Возврат Справочники.бит_омни_Контакты.ПустаяСсылка();
	КонецЕсли;

	ДанныеБота = бит_омни_ИнтеграцияСMAXПовтИсп.ДанныеБота(Бот);
	Если ДанныеБота = Неопределено Тогда
		Возврат Справочники.бит_омни_Контакты.ПустаяСсылка();
	КонецЕсли;

	ИдентификаторПользователя = ЗначениеСвойства(User, "user_id");
	Если Не ЗначениеЗаполнено(ИдентификаторПользователя) Тогда
		Возврат Справочники.бит_омни_Контакты.ПустаяСсылка();
	КонецЕсли;

	Контакт = НайтиКонтактMAX(ИдентификаторПользователя, ДанныеБота.Ссылка);
	Если Не Контакт.Пустая() Тогда
		Возврат Контакт;
	КонецЕсли;

	КонтактОбъект = Справочники.бит_омни_Контакты.СоздатьЭлемент();
	КонтактОбъект.Наименование = Лев(ПредставлениеПользователяMAX(User), 25);
	КонтактОбъект.Идентификатор = ИдентификаторПользователя;
	КонтактОбъект.Канал = Перечисления.бит_омни_КаналыСвязи.MAX;
	КонтактОбъект.Бот = ДанныеБота.Ссылка;
	КонтактОбъект.ОбменДанными.Загрузка = Истина;
	КонтактОбъект.ДополнительныеСвойства.Вставить("НеРегистрироватьДляОбмена", Истина);
	КонтактОбъект.Записать();

	Возврат КонтактОбъект.Ссылка;

КонецФункции

#КонецОбласти

#Область ОбработкаВходящихСобытий

Процедура ОбработатьСозданиеСообщения(Обновление, Бот)

	Сообщение = ЗначениеСвойства(Обновление, "message");
	Если ТипЗнч(Сообщение) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;

	Отправитель = ЗначениеСвойства(Сообщение, "sender");
	Если ЗначениеСвойства(Отправитель, "is_bot", Ложь) Тогда
		Возврат;
	КонецЕсли;

	Контакт = ПолучитьКонтактПоUser(Отправитель, Бот);
	ТекстСообщения = ТекстСообщенияMAX(Сообщение);

	Если ЭтоКомандаMAX(ТекстСообщения) Тогда
		ОбработатьКоманду(Сообщение, Контакт, Бот, КомандаИзТекста(ТекстСообщения));
	Иначе
		ОбработатьСообщение(Сообщение, Контакт, Бот);
	КонецЕсли;

	ЗаписатьСобытиеВЖурнал(Обновление, Бот, НСтр("ru='Получено сообщение MAX'"));

КонецПроцедуры

Процедура ОбработатьЗапускБота(Обновление, Бот)

	User = ЗначениеСвойства(Обновление, "user");
	Контакт = ПолучитьКонтактПоUser(User, Бот);

	Если Контакт.Пустая() Тогда
		Возврат;
	КонецЕсли;

	УстановитьБлокировкуКонтакта(Контакт, Ложь);

	Сообщение = Новый Структура;
	Сообщение.Вставить("sender", User);
	Сообщение.Вставить("timestamp", ЗначениеСвойства(Обновление, "timestamp"));

	Payload = СтроковоеСвойство(Обновление, "payload");
	Сообщение.Вставить("body", Новый Структура("text, mid", "/start " + Payload, СтроковоеСвойство(Обновление,
		"timestamp")));

	ОбработатьКоманду(Сообщение, Контакт, Бот, "/start");

	ЗаписатьСобытиеВЖурнал(Обновление, Бот, НСтр("ru='Пользователь запустил бота MAX'"));

КонецПроцедуры

Процедура ОбработатьОстановкуБота(Обновление, Бот)

	Контакт = ПолучитьКонтактПоUser(ЗначениеСвойства(Обновление, "user"), Бот);
	Если Не Контакт.Пустая() Тогда
		УстановитьБлокировкуКонтакта(Контакт, Истина);
	КонецЕсли;

	ЗаписатьСобытиеВЖурнал(Обновление, Бот, НСтр("ru='Пользователь остановил бота MAX'"));

КонецПроцедуры

Процедура ОбработатьCallback(Обновление, Бот)

	Обработчик = бит_омни_ИнтеграцияСMAXПовтИсп.ОбработчикКоманды("callback");
	Если ПустаяСтрока(Обработчик) Тогда
		ЗаписатьСобытиеВЖурнал(Обновление, Бот, НСтр("ru='Callback MAX пропущен'"));
		Возврат;
	КонецЕсли;

	ВыполнитьОбработчик(Обработчик, Обновление, Справочники.бит_омни_Контакты.ПустаяСсылка(), Бот);

КонецПроцедуры

Процедура ОбработатьСообщение(Сообщение, Контакт, Бот)

	ТелоСообщения = ЗначениеСвойства(Сообщение, "body");
	Вложения = ЗначениеСвойства(ТелоСообщения, "attachments");
	Если ТипЗнч(Вложения) = Тип("Массив") И Вложения.Количество() Тогда
		ПервоеВложение = Вложения.Получить(0);
		Если ПервоеВложение.type = "contact" Тогда
			ИнформацияОКонтакте = ЗначениеСвойства(ПервоеВложение, "payload");
			Параметры = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ИнформацияОКонтакте);
			ИнформацияОбАккаунтеMAX = ЗначениеСвойства(ИнформацияОКонтакте, "max_info");
			ИдентификаторКонтакта = ЗначениеСвойства(ИнформацияОбАккаунтеMAX, "user_id");
			Если ИдентификаторКонтакта = Контакт.Идентификатор Тогда
				ОбработатьКоманду(Сообщение, Контакт, Бот, "/contact", Параметры);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	Обработчик = бит_омни_ИнтеграцияСMAXПовтИсп.ОбработчикСообщения();
	Если ПустаяСтрока(Обработчик) Тогда
		Возврат;
	КонецЕсли;

	ВыполнитьОбработчик(Обработчик, Сообщение, Контакт, Бот);

КонецПроцедуры

Процедура ОбработатьКоманду(Сообщение, Контакт, Бот, Команда, Параметры = Неопределено)

	ИмяКоманды = СокрЛП(Команда);
	Если Лев(ИмяКоманды, 1) = "/" Тогда
		ИмяКоманды = Сред(ИмяКоманды, 2);
	КонецЕсли;

	ДействиеКоманды = РегистрыСведений.бит_омни_Команды.СоздатьМенеджерЗаписи();
	ДействиеКоманды.Команда = ИмяКоманды;
	ДействиеКоманды.Прочитать();

	Если ДействиеКоманды.Выбран() И Не ДействиеКоманды.Действие.Пустая() Тогда

		Результат = Справочники.бит_омни_Действия.ВыполнитьДействие(ДействиеКоманды.Действие, Сообщение.body.text,
			Контакт, Бот, Параметры);

		Если Не Результат.Ошибка Тогда
			Возврат;
		КонецЕсли;

		ЗаписьЖурналаРегистрации("ОМНИ.MAX.Команды", УровеньЖурналаРегистрации.Ошибка, , ДействиеКоманды.Действие,
			Результат.Описание);

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЗаголовкиMAX(Токен)

	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Authorization", Токен);

	Возврат Заголовки;

КонецФункции

Функция ПрочитатьОтветMAX(Ответ)

	ТекстОтвета = Ответ.ПолучитьТелоКакСтроку();
	ТелоОтвета = Неопределено;

	Если Не ПустаяСтрока(ТекстОтвета) Тогда
		Попытка
			ТелоОтвета = JSONВСтруктуру(ТекстОтвета);
		Исключение
			ТелоОтвета = Новый Структура("raw", ТекстОтвета);
		КонецПопытки;
	КонецЕсли;

	Возврат Новый Структура("Текст, Тело", ТекстОтвета, ТелоОтвета);

КонецФункции

Функция JSONВСтруктуру(СтрокаJSON)

	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(СтрокаJSON);
	Возврат ПрочитатьJSON(Чтение);

КонецФункции

Функция СтруктураВJSON(Данные)

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);

	Возврат ЗаписьJSON.Закрыть();

КонецФункции

Функция ПараметрыСообщенияMAX(ПараметрыСообщения, Получатель, Контекст)

	Если Не ЭтоШаблонСообщенияMAX(ПараметрыСообщения) Тогда
		Возврат ПараметрыСообщения;
	КонецЕсли;

	ТекстСообщения = бит_омни_РаботаССообщениями.СформироватьТекстСообщенияПоШаблону(ПараметрыСообщения, Получатель,
		Контекст);
	ПараметрыТекущегоСообщения = Новый Структура("text", ТекстСообщения);

	Формат = ПараметрыСообщения.ВариантФормата;
	Если ЗначениеЗаполнено(Формат) Тогда
		ПараметрыТекущегоСообщения.Вставить("format", Формат);
	КонецЕсли;

	Возврат ПараметрыТекущегоСообщения;

КонецФункции

Функция ЭтоШаблонСообщенияMAX(ПараметрыСообщения)

	ТипПараметров = ТипЗнч(ПараметрыСообщения);

	Возврат ТипПараметров = Тип("СправочникСсылка.бит_омни_ШаблоныСообщений") Или ТипПараметров = Тип(
		"СправочникОбъект.бит_омни_ШаблоныСообщений");

КонецФункции

Функция ПолучателиСообщенияMAX(Получатели)

	Результат = Новый Массив;

	Если ТипЗнч(Получатели) = Тип("Массив") Тогда
		ИсходныеПолучатели = Получатели;
	Иначе
		ИсходныеПолучатели = Новый Массив;
		ИсходныеПолучатели.Добавить(Получатели);
	КонецЕсли;

	Для Каждого Получатель Из ИсходныеПолучатели Цикл

		Если Получатель = Неопределено Или Получатель = Null Тогда
			Продолжить;
		КонецЕсли;

		Если Результат.Найти(Получатель) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Если ПолучательЗаблокированMAX(Получатель) Тогда
			Продолжить;
		КонецЕсли;

		Результат.Добавить(Получатель);

	КонецЦикла;

	Возврат Результат;

КонецФункции

Функция ПолучательСообщенияMAX(Получатель, Бот)

	ДоступныеТипыПолучателей = ДоступныеТипыПолучателейMAX();

	Если ДоступныеТипыПолучателей.СодержитТип(ТипЗнч(Получатель)) Тогда
		Получатель = НайтиКонтактПоДанным1С(Получатель, Бот);
	КонецЕсли;

	Если Получатель.Пустая() Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат Получатель;

КонецФункции

Функция ДоступныеТипыПолучателейMAX()

	Возврат Метаданные.Справочники.бит_омни_Контакты.Реквизиты.Получатель.Тип;

КонецФункции
Функция ПолучательЗаблокированMAX(Получатель)

	Если ТипЗнч(Получатель) <> Тип("СправочникСсылка.бит_омни_Контакты") Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Получатель.Пустая() Тогда
		Возврат Истина;
	КонецЕсли;

	РеквизитыПолучателя = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Получатель, "Заблокирован");
	Возврат РеквизитыПолучателя.Заблокирован;

КонецФункции

Функция ТелоСообщенияMAX(ПараметрыСообщения)

	Если ТипЗнч(ПараметрыСообщения) = Тип("Строка") Или ТипЗнч(ПараметрыСообщения) = Тип("ФорматированнаяСтрока") Тогда
		Возврат Новый Структура("text", Строка(ПараметрыСообщения));
	КонецЕсли;

	Если ТипЗнч(ПараметрыСообщения) <> Тип("Структура") Тогда
		Возврат Неопределено;
	КонецЕсли;

	ЕстьТекст = ЗначениеЗаполнено(СтроковоеСвойство(ПараметрыСообщения, "text"));
	ЕстьВложения = ЗначениеСвойства(ПараметрыСообщения, "attachments") <> Неопределено;

	Если Не ЕстьТекст И Не ЕстьВложения Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат ПараметрыСообщения;

КонецФункции

Функция ПараметрыАдресата(Получатель, Бот)

	Если ТипЗнч(Получатель) = Тип("СправочникСсылка.бит_омни_Контакты") Тогда

		Если Получатель.Пустая() Тогда
			Возврат Неопределено;
		КонецЕсли;

		РеквизитыПолучателя = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Получатель, "Идентификатор");
		Если ЗначениеЗаполнено(РеквизитыПолучателя.Идентификатор) Тогда
			Возврат Новый Структура("Параметр, Значение", "user_id", СтрокаИдентификатора(
				РеквизитыПолучателя.Идентификатор));
		КонецЕсли;

		Возврат Неопределено;

	КонецЕсли;

	Если ТипЗнч(Получатель) = Тип("Структура") Тогда

		Если ЗначениеЗаполнено(ЗначениеСвойства(Получатель, "chat_id")) Тогда
			Возврат Новый Структура("Параметр, Значение", "chat_id", СтрокаИдентификатора(Получатель.chat_id));
		ИначеЕсли ЗначениеЗаполнено(ЗначениеСвойства(Получатель, "user_id")) Тогда
			Возврат Новый Структура("Параметр, Значение", "user_id", СтрокаИдентификатора(Получатель.user_id));
		КонецЕсли;

		Возврат Неопределено;

	КонецЕсли;

	Если ТипЗнч(Получатель) = Тип("Число") Или ТипЗнч(Получатель) = Тип("Строка") Тогда
		Возврат Новый Структура("Параметр, Значение", "user_id", СтрокаИдентификатора(Получатель));
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

Функция НайтиКонтактПоДанным1С(Ссылка, Бот)

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
				   |	бит_омни_Контакты.Ссылка КАК Ссылка
				   |ИЗ
				   |	Справочник.бит_омни_Контакты КАК бит_омни_Контакты
				   |ГДЕ
				   |	бит_омни_Контакты.Получатель = &Ссылка
				   |	И бит_омни_Контакты.Бот = &Бот
				   |	И бит_омни_Контакты.Канал = ЗНАЧЕНИЕ(Перечисление.бит_омни_КаналыСвязи.MAX)
				   |	И НЕ бит_омни_Контакты.ПометкаУдаления
				   |	И НЕ бит_омни_Контакты.Заблокирован";

	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("Бот", Бот);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Справочники.бит_омни_Контакты.ПустаяСсылка();

КонецФункции
Функция НайтиКонтактMAX(ИдентификаторПользователя, Бот)

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
				   |	бит_омни_Контакты.Ссылка КАК Ссылка
				   |ИЗ
				   |	Справочник.бит_омни_Контакты КАК бит_омни_Контакты
				   |ГДЕ
				   |	бит_омни_Контакты.Идентификатор = &Идентификатор
				   |	И бит_омни_Контакты.Бот = &Бот
				   |	И бит_омни_Контакты.Канал = ЗНАЧЕНИЕ(Перечисление.бит_омни_КаналыСвязи.MAX)
				   |	И НЕ бит_омни_Контакты.ПометкаУдаления";

	Запрос.УстановитьПараметр("Идентификатор", ИдентификаторПользователя);
	Запрос.УстановитьПараметр("Бот", Бот);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	КонецЕсли;

	Возврат Справочники.бит_омни_Контакты.ПустаяСсылка();

КонецФункции

Процедура УстановитьБлокировкуКонтакта(Контакт, Заблокирован)

	Если Контакт.Пустая() Тогда
		Возврат;
	КонецЕсли;

	КонтактОбъект = Контакт.ПолучитьОбъект();
	Если КонтактОбъект.Заблокирован = Заблокирован Тогда
		Возврат;
	КонецЕсли;

	КонтактОбъект.Заблокирован = Заблокирован;
	КонтактОбъект.ОбменДанными.Загрузка = Истина;
	КонтактОбъект.ДополнительныеСвойства.Вставить("НеРегистрироватьДляОбмена", Истина);
	КонтактОбъект.Записать();

КонецПроцедуры

Функция ПредставлениеПользователяMAX(User)

	Имя = СтроковоеСвойство(User, "first_name");
	Фамилия = СтроковоеСвойство(User, "last_name");
	ИмяУстаревшее = СтроковоеСвойство(User, "name");
	Username = СтроковоеСвойство(User, "username");

	Представление = СокрЛП(Имя + " " + Фамилия);
	Если ПустаяСтрока(Представление) Тогда
		Представление = ИмяУстаревшее;
	КонецЕсли;

	Если ПустаяСтрока(Представление) Тогда
		Представление = Username;
	КонецЕсли;

	Если ПустаяСтрока(Представление) Тогда
		Представление = СтрокаИдентификатора(ЗначениеСвойства(User, "user_id"));
	КонецЕсли;

	Возврат Представление;

КонецФункции

Функция ТекстСообщенияMAX(Сообщение)

	Тело = ЗначениеСвойства(Сообщение, "body");
	Возврат СтроковоеСвойство(Тело, "text");

КонецФункции

Функция ЭтоКомандаMAX(ТекстСообщения)

	Возврат ЗначениеЗаполнено(ТекстСообщения) И Лев(СокрЛП(ТекстСообщения), 1) = "/";

КонецФункции

Функция КомандаИзТекста(ТекстСообщения)

	ЧастиКоманды = СтрРазделить(СокрЛП(ТекстСообщения), " ");
	Если ЧастиКоманды.Количество() = 0 Тогда
		Возврат "";
	КонецЕсли;

	Возврат ЧастиКоманды[0];

КонецФункции

Функция СтроковоеСвойство(Данные, ИмяСвойства, ЗначениеПоУмолчанию = "")

	Значение = ЗначениеСвойства(Данные, ИмяСвойства, ЗначениеПоУмолчанию);
	Если Значение = Неопределено Или Значение = Null Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Возврат СокрЛП(Строка(Значение));

КонецФункции

Функция ЗначениеСвойства(Данные, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)

	Если ТипЗнч(Данные) <> Тип("Структура") Тогда
		Возврат ЗначениеПоУмолчанию;
	КонецЕсли;

	Значение = Неопределено;
	Если Данные.Свойство(ИмяСвойства, Значение) Тогда
		Возврат Значение;
	КонецЕсли;

	Возврат ЗначениеПоУмолчанию;

КонецФункции

Функция СтрокаИдентификатора(Идентификатор)

	Если Идентификатор = Неопределено Или Идентификатор = Null Тогда
		Возврат "";
	КонецЕсли;

	Если ТипЗнч(Идентификатор) = Тип("Число") Тогда
		Возврат Формат(Идентификатор, "ЧГ=0");
	КонецЕсли;

	Возврат СокрЛП(Строка(Идентификатор));

КонецФункции

Процедура ВыполнитьОбработчик(Обработчик, Сообщение, Контакт, Бот)

	Попытка
		УстановитьБезопасныйРежим(Истина);
		Выполнить (СтрШаблон("%1(Сообщение, Контакт, Бот);", Обработчик));
	Исключение
		//@skip-check undefined-type
		ЗаписьЖурналаРегистрации(
			"ОМНИ.MAX.ОшибкаОбработчика", УровеньЖурналаРегистрации.Ошибка, , , 
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;

КонецПроцедуры

Процедура ЗаписатьСобытиеВЖурнал(Обновление, Бот, Комментарий)

	ТипОбновления = СтроковоеСвойство(Обновление, "update_type");
	ИдентификаторСообщения = "";

	Сообщение = ЗначениеСвойства(Обновление, "message");
	Если ТипЗнч(Сообщение) = Тип("Структура") Тогда
		Тело = ЗначениеСвойства(Сообщение, "body");
		ИдентификаторСообщения = СтроковоеСвойство(Тело, "mid");
	КонецЕсли;

	ЗаписьЖурналаРегистрации(
		"ОМНИ.MAX.Webhook", УровеньЖурналаРегистрации.Информация, , , СтрШаблон("%1. Тип: %2. MessageID: %3",
		Комментарий, ТипОбновления, ИдентификаторСообщения));

КонецПроцедуры


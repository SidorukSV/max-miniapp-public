// Найти объекты по номеру телефона.
//
// Параметры:
//  НомерТелефона		 - Строка - номер телефона 
//  ТипОбъекта			 - Тип - тип объекта
//  ИсключатьПомеченные	 - Булево - исключать помеченные
// 
// Возвращаемое значение:
//  Массив - контакты.
//
Функция НайтиОбъектыПоНомеруТелефона(НомерТелефона, ТипОбъекта = Неопределено, ИсключатьПомеченные = Ложь, ВидКонтактнойИнформации = Неопределено) Экспорт
	
	Контакты = Новый Массив;
	
	ИмяТаблицы = "";
	Если ТипОбъекта <> Неопределено Тогда 
		МетаданныеОбъекта = Метаданные.НайтиПоТипу(ТипОбъекта);
		Если МетаданныеОбъекта <> Неопределено Тогда 
			ИмяТаблицы = МетаданныеОбъекта.ПолноеИмя();
		КонецЕсли;
	КонецЕсли;
	
	Если СтрДлина(НомерТелефона) >= 9 Тогда
		НормализованныйНомер = КонтактнаяИнформацияКлиентСерверПереопределяемый.НормализоватьСотовыйТелефон(НомерТелефона);
		СтрокаНомераТелефонаДляПоиска = "%" + НормализованныйНомер.ДляПоиска + "%";
	Иначе
		СтрокаНомераТелефонаДляПоиска = НомерТелефона;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КонтактнаяИнформация.Объект,
	|	КонтактнаяИнформация.Представление КАК НомерТелефона
	|ИЗ
	|	РегистрСведений.КонтактнаяИнформация КАК КонтактнаяИнформация
	|ГДЕ
	|	&УсловиеПоТипуОбъекта
	|	И &УсловиеПоВидуКонтактнойИнформации
	|	И КонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Телефон)
	|	И (НЕ &ИсключатьПомеченные
	|		ИЛИ НЕ КонтактнаяИнформация.Объект.ПометкаУдаления)
	|	И КонтактнаяИнформация.Представление ПОДОБНО &НомерТелефона";
	
	Запрос.УстановитьПараметр("УсловиеПоТипуОбъекта", Истина);
	Запрос.УстановитьПараметр("УсловиеПоВидуКонтактнойИнформации", Истина);

	Если Не ПустаяСтрока(ИмяТаблицы) Тогда 
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоТипуОбъекта", "КонтактнаяИнформация.Объект ССЫЛКА " + ИмяТаблицы);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ВидКонтактнойИнформации) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоВидуКонтактнойИнформации", "КонтактнаяИнформация.Вид = &ВидКонтактнойИнформации");
		Запрос.УстановитьПараметр("ВидКонтактнойИнформации", ВидКонтактнойИнформации);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ИсключатьПомеченные", ИсключатьПомеченные);
	Запрос.УстановитьПараметр("НомерТелефона", СтрокаНомераТелефонаДляПоиска);
	
	Результат = Запрос.Выполнить();
	
	Найден = Ложь;
	Если Результат.Пустой() Тогда
		КлиентСсылка = Справочники.Клиенты.ПустаяСсылка();
	Иначе
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			НомерЦифр = КонтактнаяИнформацияКлиентСерверПереопределяемый.НормализоватьСотовыйТелефон(Выборка.НомерТелефона, Ложь); 
			Контакты.Добавить(Новый Структура("Объект, Номер, НомерЦифровой", Выборка.Объект, Выборка.НомерТелефона, НомерЦифр));
		КонецЦикла;
	КонецЕсли;
	
	Возврат Контакты;
	
КонецФункции
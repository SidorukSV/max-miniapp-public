#Область РаботаСФайлами

Функция СохранитьПрикрепленныйФайл(Файл)
	
	ДвоичныеДанныеФайла = Файл.Хранилище.Получить(); 
	УчетнаяПолитика = ПараметрыСеанса.УчетнаяПолитика;
	
	Если УчетнаяПолитика.ХранитьФотоКлиентовКакФайлы 
		ИЛИ ДвоичныеДанныеФайла = Неопределено 
	Тогда //Храним файлами     
		ОбщийМодульРаботыСФайлами = ОбщегоНазначения.ОбщийМодуль("РаботаСФайлами");
		КаталогХраненияФайла = ОбщийМодульРаботыСФайлами.ПолучитьБазовыйКаталогФайлов(Файл.Объект);
		ИмяФайла = КаталогХраненияФайла + Файл.Наименование;
	Иначе
		ИмяФайла = ПолучитьИмяВременногоФайла(Файл.Расширение);
		ДвоичныеДанныеФайла.Записать(ИмяФайла);
	КонецЕсли;
	
	Возврат ИмяФайла;
	
КонецФункции

Функция ПолучитьФайлПоID(file_id, HTTPСоединения)
	
	HTTPЗапрос = Новый HTTPЗапрос("/getFile?file_id=" + file_id);
	HTTPОтвет = HTTPСоединения.Основное.Получить(HTTPЗапрос);
	
	ТекстОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстОтвета);
	
	СтруктураОтвета = ПрочитатьJSON(ЧтениеJSON);
	
	Если СтруктураОтвета.ok = Истина Тогда
		
		СоставИмениФайла = СтрРазделить(СтруктураОтвета.result.file_path, ".");
		СоставПутиФайла = СтрРазделить(СтруктураОтвета.result.file_path, "/");
		
		ИмяФайла = СоставПутиФайла[СоставПутиФайла.ВГраница()];
		Расширение = СоставИмениФайла[СоставИмениФайла.ВГраница()];
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла(Расширение);
		
		HTTPЗапрос = Новый HTTPЗапрос("/" + СтруктураОтвета.result.file_path);
		HTTPСоединения.Файлы.Получить(HTTPЗапрос, ИмяВременногоФайла);
		СтруктраВозврата = Новый Структура("ИмяФайла, ПутьКФайлу", ИмяФайла, ИмяВременногоФайла);
		
		Возврат СтруктраВозврата;
		
	КонецЕсли;
	
КонецФункции


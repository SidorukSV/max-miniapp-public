Функция ПолучитьПолучателей(Источник) Экспорт
	
	ТипДокумента = Источник.Метаданные().ПолноеИмя();
	Обработчик = бит_омни_РаботаССообщениямПовтИсп.ОбработчикПолучателей(ТипДокумента);
	
	Попытка
		Возврат Вычислить(Обработчик + "(Источник)");
	Исключение
		Возврат Новый Массив;
	КонецПопытки;
	
КонецФункции

Процедура ОтправитьСообщениеВТелеграм(HTTPСоединения = Неопределено, ШаблонСообщения, Контекст = Неопределено, Получатели, Отправитель = Неопределено, Формат = Неопределено, Вложения = Неопределено, ОтправлятьОтправителю = Ложь) Экспорт
	
	Если HTTPСоединения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(HTTPСоединения) = Тип("СправочникСсылка.бит_омни_Боты") Тогда
		HTTPСоединения = СоздатьСоединение(HTTPСоединения);
	КонецЕсли;
	
	HTTPСоединение = HTTPСоединения.Основное;
	
	МассивКонтактов = Новый Массив;
	
	Если ТипЗнч(Получатели) <> Тип("Массив") Тогда
		мсПолучатели = Новый Массив;
		мсПолучатели.Добавить(Получатели);
	Иначе
		мсПолучатели = Получатели;
	КонецЕсли;
	
	Для Каждого Получатель Из мсПолучатели Цикл
		
		Если МассивКонтактов.Найти(Получатель) <> Неопределено Тогда 		
			Продолжить;	
		КонецЕсли;
		
		Если (ОтправлятьОтправителю ИЛИ Отправитель <> Получатель)
			И НЕ Получатель.Заблокирован 
		Тогда
			МассивКонтактов.Добавить(Получатель);
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого Получатель Из МассивКонтактов Цикл
		
		Если ТипЗнч(ШаблонСообщения) = Тип("ФорматированнаяСтрока") ИЛИ ТипЗнч(ШаблонСообщения) = Тип("Строка") Тогда
			ТекстСообщения = ШаблонСообщения;
		Иначе
			Формат = ШаблонСообщения.ВариантФормата;
			ТекстСообщения = СформироватьТекстСообщенияПоШаблону(ШаблонСообщения, Получатель, Контекст);
		КонецЕсли;
		
		ИдентификаторПолучателя = Получатель.Идентификатор;
		
		Если НЕ ПустаяСтрока(ТекстСообщения) Тогда
			ОтправитьТекстовоеСообщение(HTTPСоединение, ИдентификаторПолучателя, ТекстСообщения, Контекст, Формат, HTTPСоединения.Бот);
		КонецЕсли;	
		
		Если Вложения <> Неопределено Тогда
			
			Для Каждого Вложение Из Вложения Цикл
				ОтправитьВложение(HTTPСоединение, ИдентификаторПолучателя, Вложение, Контекст, HTTPСоединения.Бот);
			КонецЦикла;
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьИнформациюОБоте(ИдентификаторБота) Экспорт
	
	СтруктураБота = Новый Структура("Идентификатор", ИдентификаторБота);
	HTTPСоединение = СоздатьСоединение(СтруктураБота);
	HTTPЗапрос = Новый HTTPЗапрос("getMe");
	HTTPОТвет = HTTPСоединение.Основное.Получить(HTTPЗапрос);
	
	ДанныеСтрокой = HTTPОтвет.ПолучитьТелоКакСтроку();	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ДанныеСтрокой);
	
	РезультатЗапроса = ПрочитатьJSON(ЧтениеJSON);
	Возврат РезультатЗапроса.result;
	
КонецФункции

Функция СформироватьТекстСообщенияПоШаблону(Шаблон, Получатель, Контекст) Экспорт
	
	ТекстСообщения = Шаблон.ШаблонСообщения;
	НачалоБлока = ?(Шаблон.ВариантФормата = "HTML", "{{ ", "<");
	КонецБлока = ?(Шаблон.ВариантФормата = "HTML", " }}", ">"); 
	
	Для Каждого ПолеШаблона Из Шаблон.ПоляШаблона Цикл
		Поле = НачалоБлока + ПолеШаблона.Поле + КонецБлока;
		Результат = "";
		Выполнить(ПолеШаблона.АлгоритмРасчета);
		ТекстСообщения = СтрЗаменить(ТекстСообщения, Поле, Результат);
	КонецЦикла;
	
	Возврат ТекстСообщения;
	
КонецФункции

Функция Упоминание(Контакт) Экспорт

	Шаблон = "<a href=""tg://user?id=%2"">%1</a>";

	|	бит_омни_Боты.Ссылка,
	|	бит_омни_Боты.Идентификатор";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "//%ПЕРВЫЕОДИН%", ?(ПолучитьВсе, "", "ПЕРВЫЕ 1"));

Функция СоздатьСоединение(Бот)
	
	ШаблонСтрокиURLДляФайлов = "api.telegram.org/file/bot%1/";	
	ШаблонСтрокиURL = "api.telegram.org/bot%1/";
	
	URL = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонСтрокиURL, Бот.Идентификатор);
	URLДляФайлов = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонСтрокиURLДляФайлов, Бот.Идентификатор);
	
	ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL(Новый СертификатКлиентаWindows());
	HTTPСоединение = Новый HTTPСоединение(URL,,,,,,ЗащищенноеСоединение);
	HTTPСоединениеДляФайлов = Новый HTTPСоединение(URLДляФайлов,,,,,,ЗащищенноеСоединение);
	
	СтруктураВозврата = Новый Структура("Основное, Файлы, Бот", HTTPСоединение, HTTPСоединениеДляФайлов, Бот);
	
	Возврат СтруктураВозврата;

КонецФункции

Функция ПолучитьСамоеПервоеСообщениеПоСсылке(Ссылка, Контакт)

	ИдентификаторОбсуждения = Ссылка.УникальныйИдентификатор();
	

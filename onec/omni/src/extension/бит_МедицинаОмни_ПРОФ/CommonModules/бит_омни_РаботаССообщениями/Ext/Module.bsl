Процедура УстановитьСтатус(Знач HTTPСоединение, Знач ИдентификаторПолучателя, Статус)
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json");
	Заголовки.Вставить("Host", "api.telegram.org");
	
	HTTPЗапрос = Новый HTTPЗапрос("/sendChatAction", Заголовки);
	
	СтруктураСообщения = Новый Структура;
	СтруктураСообщения.Вставить("chat_id", ИдентификаторПолучателя);
	СтруктураСообщения.Вставить("action", Статус);
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, СтруктураСообщения);
	СтрокаЗапроса = ЗаписьJSON.Закрыть();
	
	HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаЗапроса);
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);

КонецПроцедуры

Процедура ОтправитьТекстовоеСообщение(Знач HTTPСоединение, Знач ИдентификаторПолучателя, Знач ТекстСообщения, Контекст = Неопределено, Формат = Неопределено, Бот) 
	
	УстановитьСтатус(HTTPСоединение, ИдентификаторПолучателя, "typing");	
		
	Контакт = Справочники.бит_омни_Контакты.НайтиПоРеквизиту("Идентификатор", ИдентификаторПолучателя);

	ReplyTo = Неопределено;

	СтруктураСообщения = Новый Структура;
	СтруктураСообщения.Вставить("chat_id", ИдентификаторПолучателя);
	СтруктураСообщения.Вставить("text", Строка(ТекстСообщения));

	Если ReplyTo <> Неопределено Тогда
		СтруктураСообщения.Вставить("reply_to_message_id", ReplyTo);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(формат) Тогда
		СтруктураСообщения.Вставить("parse_mode", Формат);
	КонецЕсли;
	
	Inline_keyboard = ДобавитьКомандыКСообщению(Контакт, Контекст);
	
	Если Inline_keyboard.Количество() > 0 Тогда
		СтруктураСообщения.Вставить("reply_markup", Новый Структура);
		СтруктураСообщения.reply_markup.Вставить("inline_keyboard", Inline_keyboard);
	КонецЕсли;
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, СтруктураСообщения);
	СтрокаЗапроса = ЗаписьJSON.Закрыть();
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json");
	Заголовки.Вставить("Host", "api.telegram.org");
	HTTPЗапрос = Новый HTTPЗапрос("/sendMessage", Заголовки);
	HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаЗапроса);
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	ТекстОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстОтвета);
	СтруктураОтвета = ПрочитатьJSON(ЧтениеJSON);

	Если СтруктураОтвета.ok = Истина Тогда
		Если Контекст <> Неопределено Тогда
			ЗарегистрироватьСообщение(СтруктураОтвета.result.message_id, Контекст, Контакт, Бот);
		КонецЕсли;
	Иначе
		ОбщегоНазначения.СообщитьПользователю(СтруктураОтвета.description,,"Не удалось отправить сообщение в  пользователю " + Контакт.Наименование);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтправитьВложение(Знач HTTPСоединение, Знач ИдентификаторПолучателя, Знач Вложение, Контекст = Неопределено, Бот)
	
	УстановитьСтатус(HTTPСоединение, ИдентификаторПолучателя, "upload_document");
	Контакт = Справочники.бит_омни_Контакты.НайтиПоРеквизиту("Идентификатор", ИдентификаторПолучателя);
	
	Если Контекст <> Неопределено Тогда
		ReplyTo = ПолучитьСамоеПервоеСообщениеПоСсылке(Контекст, Контакт);
	Иначе
		ReplyTo = Неопределено;
	КонецЕсли;

	СтруктураСообщения = Новый Структура;
	СтруктураСообщения.Вставить("chat_id", Формат(ИдентификаторПолучателя, "ЧГ=0"));

	Если ReplyTo <> Неопределено Тогда
		СтруктураСообщения.Вставить("reply_to_message_id", Формат(ReplyTo, "ЧГ=0"));
	КонецЕсли;
	
	Разделитель = "----" + Строка(Новый УникальныйИдентификатор());
	ПутьКФайлу = СохранитьПрикрепленныйФайл(Вложение);
	ИмяФайла = Вложение.Наименование;
	
	Файл = Новый Файл(ПутьКФайлу);

	//Определяем массив для процедуры ОбъединитьФайлы
	МассивФайловДляОбъединения = Новый Массив;
	
	МассивФайловДляОбъединения.Добавить(ПолучитьИмяВременногоФайла("txt"));
	ФайлОтправкиНачало = Новый ЗаписьТекста(МассивФайловДляОбъединения[0], КодировкаТекста.UTF8);
	НачальныеДанные = "--%Разделитель%
	|Content-Disposition: form-data; name=""chat_id""
	|
	|%chat_id%
	|--%Разделитель%
	|Content-Disposition: form-data; name=""reply_to_message_id""
	|
	|%reply_to_message_id%
	|--%Разделитель%
	|Content-Disposition: form-data; name=""document""; filename=""%ИмяФайла%""
	|";
	НачальныеДанные = СтрЗаменить(НачальныеДанные,"%Разделитель%",Разделитель);
	НачальныеДанные = СтрЗаменить(НачальныеДанные,"%chat_id%",СтруктураСообщения.chat_id);
	НачальныеДанные = СтрЗаменить(НачальныеДанные,"%reply_to_message_id%",?(СтруктураСообщения.Свойство("reply_to_message_id"), СтруктураСообщения.reply_to_message_id, ""));
	НачальныеДанные = СтрЗаменить(НачальныеДанные,"%ИмяФайла%",ИмяФайла);
	
	ФайлОтправкиНачало.ЗаписатьСтроку(НачальныеДанные );
	ФайлОтправкиНачало.Закрыть();
	
	МассивФайловДляОбъединения.Добавить(ПутьКФайлу);
	
	МассивФайловДляОбъединения.Добавить(ПолучитьИмяВременногоФайла("txt"));
	ФайлаОтправкиКонец = Новый ЗаписьТекста(МассивФайловДляОбъединения[2], КодировкаТекста.UTF8);
	КонечныеДанные = "
	|--%Разделитель%--";
	КонечныеДанные = СтрЗаменить(КонечныеДанные,"%Разделитель%",Разделитель);
	
	ФайлаОтправкиКонец.ЗаписатьСтроку(КонечныеДанные);
	ФайлаОтправкиКонец.Закрыть();
	
	ИмяИтоговогоФайла = ПолучитьИмяВременногоФайла("txt");
	ОбъединитьФайлы(МассивФайловДляОбъединения, ИмяИтоговогоФайла);
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "multipart/form-data; boundary=" + Разделитель);
	Заголовки.Вставить("Host", "api.telegram.org");
	HTTPЗапрос = Новый HTTPЗапрос("/sendDocument", Заголовки);
	    	
	HTTPЗапрос.УстановитьИмяФайлаТела(ИмяИтоговогоФайла);
	HTTPОтвет = HTTPСоединение.ОтправитьДляОбработки(HTTPЗапрос);
	
	ТекстОтвета = HTTPОтвет.ПолучитьТелоКакСтроку();
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ТекстОтвета);
	
	СтруктураОтвета = ПрочитатьJSON(ЧтениеJSON);
	
	Если СтруктураОтвета.ok = Истина Тогда
		
		Если Контекст <> Неопределено Тогда
			ЗарегистрироватьСообщение(СтруктураОтвета.result.message_id, Контекст, Контакт, Бот);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры


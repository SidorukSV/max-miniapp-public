Процедура ПолучитьОбновления(Знач HTTPСоединения)
	
	Смещение = HTTPСоединения.Бот.Смещение;
	
	СтруктураСообщения = Новый Структура;
	СтруктураСообщения.Вставить("offset", ?(Смещение = Неопределено, 0, Смещение + 1));

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, СтруктураСообщения);
	
	СтрокаЗапроса = ЗаписьJSON.Закрыть();
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", "application/json");
	Заголовки.Вставить("Host", "api.telegram.org");

	HTTPЗапрос = Новый HTTPЗапрос("/disabledGetUpdates", Заголовки);
	HTTPЗапрос.УстановитьТелоИзСтроки(СтрокаЗапроса);

	HTTPОтвет = HTTPСоединения.Основное.ОтправитьДляОбработки(HTTPЗапрос);

	ДанныеСтрокой = HTTPОтвет.ПолучитьТелоКакСтроку();	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(ДанныеСтрокой);
	
	Данные = ПрочитатьJSON(ЧтениеJSON);
	
	Если ТипЗнч(Данные) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;  
		
	Если НЕ Данные.Свойство("result") ИЛИ ТипЗнч(Данные.result) <> Тип("Массив") Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаИзменений Из Данные.result Цикл
		Если ТипЗнч(СтрокаИзменений) <> Тип("Структура") ИЛИ НЕ СтрокаИзменений.Свойство("message") Тогда
			Продолжить;
		КонецЕсли;
		
		Смещение = СтрокаИзменений.update_id;
		Сообщение = СтрокаИзменений.message;
		
		Получатель = ПолучитьКонтактПоUser(Сообщение.from);
		
		Если Сообщение.chat.type <> "private" Тогда
			Чат = ПолучитьКонтактПоUser(Сообщение.chat);
		КонецЕсли;
		
		Контекст = Неопределено;
		ЭтоКоманда = Ложь;
		
		Если СтрокаИзменений.message.Свойство("text") 
			И СтрокаИзменений.message.Свойство("entities")
		Тогда
			Для Каждого entitity Из СтрокаИзменений.message.entities Цикл
				Если entitity.type = "bot_command" Тогда
					Команда = Сред(Сообщение.text, entitity.offset + 1, entitity.length);
					ЭтоКоманда = Истина;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Если ЭтоКоманда Тогда
			ОбработатьКоманду(HTTPСоединения, Получатель, Сообщение, Контекст, Команда);
		Иначе
			ОбработатьСообщение(HTTPСоединения, СтрокаИзменений.message, Получатель);
		КонецЕсли;
		
		ЗарегистрироватьСообщение(СтрокаИзменений.message.message_id, Контекст, Получатель, HTTPСоединения.Бот);
	КонецЦикла;
			
	ИзменитьСмещение(HTTPСоединения.Бот, Смещение);
		
КонецПроцедуры


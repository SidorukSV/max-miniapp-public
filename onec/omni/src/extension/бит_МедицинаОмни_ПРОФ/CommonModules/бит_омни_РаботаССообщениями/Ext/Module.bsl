КонецФункции

Процедура ОбработатьРассылкиПоБоту(HTTPСоединения)

	Бот = HTTPСоединения.Бот.Ссылка;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	бит_омни_АктивныеРассылки.Рассылка КАК Рассылка,
	|	бит_омни_Рассылки.Шаблон КАК Шаблон,
	|	бит_омни_Рассылки.СКДПолучатели КАК СКДПолучатели,
	|	бит_омни_Рассылки.СКДКонтекст КАК СКДКонтекст,
	|	бит_омни_Рассылки.Расписание КАК Расписание,
	|	бит_омни_АктивныеРассылки.ДатаНачалаПоследнегоЗапуска КАК ДатаНачалаПоследнегоЗапуска,
	|	бит_омни_АктивныеРассылки.ДатаЗавершенияПоследнегоЗапуска КАК ДатаЗавершенияПоследнегоЗапуска
	|ИЗ
	|	РегистрСведений.бит_омни_АктивныеРассылки КАК бит_омни_АктивныеРассылки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.бит_омни_Рассылки КАК бит_омни_Рассылки
	|		ПО бит_омни_АктивныеРассылки.Рассылка = бит_омни_Рассылки.Ссылка
	|ГДЕ
	|	бит_омни_АктивныеРассылки.Бот = &Бот";
	
	Запрос.УстановитьПараметр("Бот", Бот);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Расписание = Выборка.Расписание.Получить();
		ТребуетсяВыполнение = Расписание.ТребуетсяВыполнение(ТекущаяДата(), Выборка.ДатаНачалаПоследнегоЗапуска, Выборка.ДатаЗавершенияПоследнегоЗапуска);
		
		Если ТребуетсяВыполнение Тогда
			
			ДатаЗапуска = ТекущаяДата();
			
			ПоследнийЗапуск = РегистрыСведений.бит_омни_АктивныеРассылки.СоздатьМенеджерЗаписи();
			ПоследнийЗапуск.Бот = Бот;
			ПоследнийЗапуск.Рассылка = Выборка.Рассылка;
			ПоследнийЗапуск.ДатаНачалаПоследнегоЗапуска = ДатаЗапуска;
			ПоследнийЗапуск.ДатаЗавершенияПоследнегоЗапуска = ДатаЗапуска;
			ПоследнийЗапуск.Записать();
			
			ПолучателиСКД = Выборка.СКДПолучатели.Получить();
			
			МодульСКД = ОбщегоНазначения.ОбщийМодуль("бит_омни_СхемыКомпоновки");
			ПараметрыСКД = МодульСКД.ПараметрыВыполненияСхемы();
			ПараметрыСКД.КудаВывести = "ТаблицаЗначений";
			
			Результат = МодульСКД.ВыполнитьСхему(ПолучателиСКД, ПараметрыСКД);
			Получатели = Результат.ВыгрузитьКолонку("Получатель");
			
			КонтекстСКД = Выборка.СКДКонтекст.Получить();
			Результат = МодульСКД.ВыполнитьСхему(КонтекстСКД, ПараметрыСКД);
			
			Если Результат.Количество() Тогда
				бит_омни_РаботаССообщениями.ОтправитьСообщениеВТелеграм(HTTPСоединения, Выборка.Шаблон, Результат, Получатели);
			КонецЕсли;                                 
			
			ПоследнийЗапуск.ДатаЗавершенияПоследнегоЗапуска = ТекущаяДата();
			ПоследнийЗапуск.Записать();
			
		КонецЕсли;
		
	КонецЦикла;
	

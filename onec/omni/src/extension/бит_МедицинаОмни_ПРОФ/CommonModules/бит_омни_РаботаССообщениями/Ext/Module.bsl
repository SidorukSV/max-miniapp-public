Функция ПолучитьКонтактПоUser(Знач User)
	
	Получатель = Справочники.бит_омни_Контакты.НайтиПоРеквизиту("Идентификатор", User.id);
	
	Если Получатель.Пустая() Тогда
		ПолучательОбъект = Справочники.бит_омни_Контакты.СоздатьЭлемент();
		Если User.Свойство("type") Тогда
			ИмяПользователя = User.title;
			Тип = User.type;
		Иначе
			ИмяПользователя = ?(User.Свойство("last_name"), User.first_name + " " + User.last_name, User.first_name);
			Тип = "private";
		КонецЕсли;
		ПолучательОбъект.Наименование = ИмяПользователя;
		ПолучательОбъект.Идентификатор = User.id;
		ПолучательОбъект.Тип = Тип;
		ПолучательОбъект.ОбменДанными.Загрузка = Истина;
		ПолучательОбъект.ДополнительныеСвойства.Вставить("НеРегистрироватьДляОбмена", Истина);
		ПолучательОбъект.УстановитьНовыйКод();
		ПолучательОбъект.Записать();
		Получатель = ПолучательОбъект.Ссылка;
	КонецЕсли;
	
	Возврат Получатель;


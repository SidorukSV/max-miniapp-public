Процедура ЗарегистрироватьСообщение(message_id, Контекст, Контакт, Бот)
	
	мзСообщение = РегистрыСведений.бит_омни_Сообщения.СоздатьМенеджерЗаписи();
	мзСообщение.Период = ТекущаяДата();
	мзСообщение.Message_id = message_id;
	
	ТипКонтекста = ТипЗнч(Контекст); 
	ЭтоСсылка = ОбщегоНазначения.ЭтоСсылка(ТипЗнч(Контекст));
	
	ИсключаемыеТипы = Новый ОписаниеТипов("Булево, Строка, Дата, Null, Число");
	
	ЕстьРеквизитСсылка = Ложь;
	Если НЕ ИсключаемыеТипы.СодержитТип(ТипКонтекста)
		И Контекст <> Неопределено 
	Тогда				  
		ЕстьРеквизитСсылка = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Контекст, "Ссылка");
	КонецЕсли;	
		
	Если ЭтоСсылка Тогда
		мзСообщение.ИдентификаторОбсуждения = Контекст.УникальныйИдентификатор();
	ИначеЕсли ЕстьРеквизитСсылка Тогда
		мзСообщение.ИдентификаторОбсуждения = Контекст.Ссылка.УникальныйИдентификатор()	
	КонецЕсли;
	
	мзСообщение.Контакт = Контакт;
	мзСообщение.Бот = Бот.Ссылка;
	
	мзСообщение.Записать();
	
КонецПроцедуры


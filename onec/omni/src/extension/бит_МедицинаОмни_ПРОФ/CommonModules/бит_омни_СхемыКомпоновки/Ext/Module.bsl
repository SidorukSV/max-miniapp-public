#Область ПрограммныйИнтерфейс

Функция ПараметрыВыполненияСхемы(КудаВывести = "ТабличныйДокумент") Экспорт
	
	Структура = Новый Структура("КудаВывести, Расшифровка, ИдентификаторФормы, ПараметрыОтчета, ВнешниеНаборыДанных");
	Структура.КудаВывести = КудаВывести;
	Структура.ПараметрыОтчета = Новый Структура;
	Структура.ВнешниеНаборыДанных = Новый Структура;
	
	Возврат Структура;
	
КонецФункции
	
Функция ВыполнитьСхему(Схема, ПараметрыВыполнения, Расшифровка = Неопределено) Экспорт
	
	ОбщийМодульБазовыеПодсистемы = ОбщегоНазначения.ОбщийМодуль("бит_омни_ОбщегоНазначения");
	
	ОписаниеТиповСхема = ОбщийМодульБазовыеПодсистемы.ОписаниеТиповСхемыКомпоновкиДанных(); 
	
	Если ТипЗнч(Схема) = Тип("СхемаКомпоновкиДанных") Тогда
		СхемаКомпоновки = Схема;
	ИначеЕсли ОписаниеТиповСхема.СодержитТип(ТипЗнч(Схема)) Тогда
		СхемаКомпоновки = Схема.ХранилищеСКД.Получить();
	Иначе
		Возврат Новый ТабличныйДокумент;
	КонецЕсли;
	
	КудаВывести = ПараметрыВыполнения.КудаВывести;
		
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;
	
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновки));
	
	КомпоновщикНастроек.ЗагрузитьНастройки(СхемаКомпоновки.НастройкиПоУмолчанию);
	
	Для Каждого КлючЗначение Из ПараметрыВыполнения.ПараметрыОтчета Цикл
		Параметр = КомпоновщикНастроек.Настройки.ПараметрыДанных.Элементы.Найти(КлючЗначение.Ключ);
		
		Если Параметр <> Неопределено Тогда
			КомпоновщикНастроек.Настройки.ПараметрыДанных.УстановитьЗначениеПараметра(КлючЗначение.Ключ, КлючЗначение.Значение);
		КонецЕсли;
	КонецЦикла;
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных();
	
	Если КудаВывести = "ТабличныйДокумент" Или КудаВывести = "Диаграмма" Тогда
		МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновки, КомпоновщикНастроек.Настройки, 
						ДанныеРасшифровки, , Тип("ГенераторМакетаКомпоновкиДанных")); 

		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
		
		РезультатВыполнения = Новый ТабличныйДокумент;
	Иначе
		МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновки, КомпоновщикНастроек.Настройки, 
						ДанныеРасшифровки, , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));

		ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
		
		Если КудаВывести = "ТаблицаЗначений" Тогда
			РезультатВыполнения = Новый ТаблицаЗначений;
		Иначе
			РезультатВыполнения = Новый ДеревоЗначений;
		КонецЕсли;
	КонецЕсли;
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных();
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки, ПараметрыВыполнения.ВнешниеНаборыДанных, ДанныеРасшифровки, Истина);
	
	ПроцессорВывода.ОтображатьПроцентВывода = Ложь;
	
	Если КудаВывести = "ТабличныйДокумент" Или КудаВывести = "Диаграмма" Тогда
		ПроцессорВывода.УстановитьДокумент(РезультатВыполнения);
	Иначе
		ПроцессорВывода.УстановитьОбъект(РезультатВыполнения);	
	КонецЕсли;
	
	ПроцессорВывода.Вывести(ПроцессорКомпоновки, Истина);
	
	Расшифровка = ПоместитьВоВременноеХранилище(ДанныеРасшифровки, ПараметрыВыполнения.ИдентификаторФормы);
	
	Если КудаВывести = "Диаграмма" Тогда
		РезультатВыполнения = РезультатКомпоновкиВДиаграмму(СхемаКомпоновки, РезультатВыполнения);
	КонецЕсли;
	
	Возврат РезультатВыполнения;
	
КонецФункции	

Функция ОписаниеНабораДанных(Схема, НаборДанных) Экспорт
	
	ТаблицаОписание = Новый ТаблицаЗначений;
	ОбщийМодульБазовыеПодсистемы = ОбщегоНазначения.ОбщийМодуль("бит_омни_ОбщегоНазначения");
	
	ОписаниеТиповСхема = ОбщийМодульБазовыеПодсистемы.ОписаниеТиповСхемыКомпоновкиДанных(); 
	
	Если ТипЗнч(Схема) = Тип("СхемаКомпоновкиДанных") Тогда
		СхемаКомпоновки = Схема;
	ИначеЕсли ОписаниеТиповСхема.СодержитТип(ТипЗнч(Схема)) Тогда
		СхемаКомпоновки = Схема.ХранилищеСКД.Получить();
	Иначе
		Возврат ТаблицаОписание;
	КонецЕсли;
	
	Набор = СхемаКомпоновки.НаборыДанных.Найти(НаборДанных);
	
	НаборНайденВКорне = Истина;
	Если Набор = Неопределено Тогда
		НаборНайденВКорне = Ложь;
	КонецЕсли;
	
	Если НЕ НаборНайденВКорне Тогда
		Для Каждого НаборОб Из СхемаКомпоновки.НаборыДанных Цикл
			Если ТипЗнч(НаборОб) = Тип("НаборДанныхОбъединениеСхемыКомпоновкиДанных") Тогда
				Набор = НаборОб.Элементы.Найти(НаборДанных);
				Если Набор <> Неопределено Тогда
					Прервать;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если Набор = Неопределено Тогда
		Возврат ТаблицаОписание;
	КонецЕсли;                        
	
	Поля = Набор.Поля;
	Для Каждого Поле Из Поля Цикл
		Если ТипЗнч(Поле) = Тип("ПолеНабораДанныхСхемыКомпоновкиДанных") Тогда
			ТаблицаОписание.Колонки.Добавить(Поле.Поле, Поле.ТипЗначения, Поле.Заголовок);
		ИначеЕсли ТипЗнч(Поле) = Тип("ВложенныйНаборДанныхСхемыКомпоновкиДанных") Тогда
			ТаблицаОписание.Колонки.Добавить(Поле.Поле, Новый ОписаниеТипов("ТаблицаЗначений"), Поле.Заголовок);
		КонецЕсли;                                                                        
	КонецЦикла;
	
	Возврат ТаблицаОписание;
	
КонецФункции

Функция ТаблицаРеквизитовМетаданных(ПолноеИмяМетаданных) Экспорт
	
	ТаблицаРеквизитов = Новый ТаблицаЗначений;
	ТаблицаРеквизитов.Колонки.Добавить("Имя");
	ТаблицаРеквизитов.Колонки.Добавить("Синоним");
	ТаблицаРеквизитов.Колонки.Добавить("ТипЗначения");
	ТаблицаРеквизитов.Колонки.Добавить("ТипПредставление");
	ТаблицаРеквизитов.Колонки.Добавить("ПолноеИмяМетаданных");
	ТаблицаРеквизитов.Колонки.Добавить("Использовать", Новый ОписаниеТипов("Булево"));
	
	МетаданныеОбъекта = МетаданныеОбъектаПоПолномуИмени(ПолноеИмяМетаданных);
	Если МетаданныеОбъекта = Неопределено Тогда
		Возврат ТаблицаРеквизитов;
	КонецЕсли;
	
	Для Каждого Реквизит Из МетаданныеОбъекта.СтандартныеРеквизиты Цикл
		ДобавитьРеквизитМетаданныхВТаблицу(ТаблицаРеквизитов, Реквизит, МетаданныеОбъекта.ПолноеИмя());
	КонецЦикла;

	Для Каждого Реквизит Из МетаданныеОбъекта.Реквизиты Цикл
		ДобавитьРеквизитМетаданныхВТаблицу(ТаблицаРеквизитов, Реквизит, МетаданныеОбъекта.ПолноеИмя());
	КонецЦикла;
	
	Возврат ТаблицаРеквизитов;
	
КонецФункции

Функция СхемаПоМетаданным(
	ПолноеИмяМетаданных,
	РеквизитыПередЗаписью,
	РеквизитыПриЗаписи,
	ИсходнаяСхема = Неопределено,
	ОбновитьТолькоНаборы = Ложь) Экспорт
	
	Если Не ЕстьВыбранныеРеквизиты(РеквизитыПередЗаписью)
		И Не ЕстьВыбранныеРеквизиты(РеквизитыПриЗаписи) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ОбновитьТолькоНаборы И ТипЗнч(ИсходнаяСхема) = Тип("СхемаКомпоновкиДанных") Тогда
		СхемаКомпоновки = ИсходнаяСхема;
	Иначе
		СхемаКомпоновки = Новый СхемаКомпоновкиДанных;
	КонецЕсли;
	
	УдалитьНаборДанныхЕслиЕсть(СхемаКомпоновки, "ПередЗаписью");
	УдалитьНаборДанныхЕслиЕсть(СхемаКомпоновки, "ПриЗаписи");
	
	Если ЕстьВыбранныеРеквизиты(РеквизитыПередЗаписью) Тогда
		ДобавитьНаборДанныхОбъект(СхемаКомпоновки, "ПередЗаписью", РеквизитыПередЗаписью, "До", " (до)");
	КонецЕсли;
	
	Если ЕстьВыбранныеРеквизиты(РеквизитыПриЗаписи) Тогда
		ДобавитьНаборДанныхОбъект(СхемаКомпоновки, "ПриЗаписи", РеквизитыПриЗаписи, "После", " (после)");
	КонецЕсли;
	
	ОбновитьНастройкиПоУмолчанию(СхемаКомпоновки);
	
	Возврат СхемаКомпоновки;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция МетаданныеОбъектаПоПолномуИмени(ПолноеИмяМетаданных)
	
	Если Не ЗначениеЗаполнено(ПолноеИмяМетаданных) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Возврат Метаданные.НайтиПоПолномуИмени(ПолноеИмяМетаданных);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
	
КонецФункции

Процедура ДобавитьРеквизитМетаданныхВТаблицу(ТаблицаРеквизитов, Реквизит, ПолноеИмяМетаданных)
	
	ДобавитьОписаниеРеквизитаВТаблицу(
		ТаблицаРеквизитов,
		Реквизит.Имя,
		Строка(Реквизит.Синоним),
		Реквизит.Тип,
		ПолноеИмяМетаданных);
	
КонецПроцедуры

Процедура ДобавитьОписаниеРеквизитаВТаблицу(ТаблицаРеквизитов, Имя, Синоним, ТипЗначения, ПолноеИмяМетаданных)
	
	Если ТаблицаРеквизитов.Найти(Имя, "Имя") <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаРеквизита = ТаблицаРеквизитов.Добавить();
	СтрокаРеквизита.Имя = Имя;
	СтрокаРеквизита.Синоним = ?(ЗначениеЗаполнено(Синоним), Синоним, Имя);
	СтрокаРеквизита.ТипЗначения = ТипЗначения;
	СтрокаРеквизита.ТипПредставление = Строка(ТипЗначения);
	СтрокаРеквизита.ПолноеИмяМетаданных = ПолноеИмяМетаданных;
	СтрокаРеквизита.Использовать = Ложь;
	
КонецПроцедуры

Функция ЕстьВыбранныеРеквизиты(Реквизиты)
	
	Если Реквизиты = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Для Каждого СтрокаРеквизита Из Реквизиты Цикл
		Если РеквизитОтмеченДляГенерации(СтрокаРеквизита) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

Функция РеквизитОтмеченДляГенерации(СтрокаРеквизита)
	
	Попытка
		Если СтрокаРеквизита.Использовать = Ложь Тогда
			Возврат Ложь;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат ЗначениеЗаполнено(СтрокаРеквизита.Имя);
	
КонецФункции

Процедура УдалитьНаборДанныхЕслиЕсть(СхемаКомпоновки, ИмяНабора)
	
	НаборДанных = СхемаКомпоновки.НаборыДанных.Найти(ИмяНабора);
	Если НаборДанных <> Неопределено Тогда
		СхемаКомпоновки.НаборыДанных.Удалить(НаборДанных);
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьНаборДанныхОбъект(СхемаКомпоновки, ИмяНабора, Реквизиты, СуффиксПутиКДанным, СуффиксЗаголовка)
	
	НаборДанных = СхемаКомпоновки.НаборыДанных.Добавить(Тип("НаборДанныхОбъектСхемыКомпоновкиДанных"));
	НаборДанных.Имя = ИмяНабора;
	НаборДанных.ИмяОбъекта = ИмяНабора;
	НаборДанных.ИсточникДанных = "ИсточникДанных1";
	
	Для Каждого СтрокаРеквизита Из Реквизиты Цикл
		
		Если Не РеквизитОтмеченДляГенерации(СтрокаРеквизита) Тогда
			Продолжить;
		КонецЕсли;
		
		Поле = НаборДанных.Поля.Добавить(Тип("ПолеНабораДанныхСхемыКомпоновкиДанных"));
		Поле.Поле = СтрокаРеквизита.Имя;
		Поле.ПутьКДанным = СтрокаРеквизита.Имя + СуффиксПутиКДанным;
		Поле.ТипЗначения = СтрокаРеквизита.ТипЗначения;
		Поле.Заголовок = СтрокаРеквизита.Синоним + СуффиксЗаголовка;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьНастройкиПоУмолчанию(СхемаКомпоновки)
	
	Попытка
		КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных;
		КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновки));
		КомпоновщикНастроек.ЗагрузитьНастройки(СхемаКомпоновки.НастройкиПоУмолчанию);
		СхемаКомпоновки.ВариантыНастроек.Очистить();
		ВариантНастроекКомпоновки = СхемаКомпоновки.ВариантыНастроек.Добавить();
		ВариантНастроекКомпоновки.Имя = "НастройкиПоУмолчанию";
		ВариантНастроекКомпоновки.Представление = "Настройки по умолчанию";	Исключение
	КонецПопытки;
	
КонецПроцедуры

Функция РезультатКомпоновкиВДиаграмму(СхемаКомпоновки, ТабДокРезультат)
	
    Диаграмма = Новый Диаграмма;

	Попытка
		Рисунок = ТабДокРезультат.Рисунки[0].Объект;
	Исключение
		Возврат Диаграмма;
	КонецПопытки;
	
	НастройкиКомпоновщика = СхемаКомпоновки.НастройкиПоУмолчанию;
	
	Диаграмма.Очистить();
	
	Попытка
		ЗаполнитьЗначенияСвойств(Диаграмма, Рисунок, , "АктивнаяТочка, АктивнаяСерия, СерияНаОсиТочек");
	Исключение
		ЗаполнитьЗначенияСвойств(Диаграмма, Рисунок, , "АктивнаяТочка, АктивнаяСерия");
	КонецПопытки;
	
	Диаграмма.Обновление = Ложь;
	Диаграмма.Очистить();
	
	//Прочитаем хитрые свойства
	СвойстваДиаграммы = НастройкиКомпоновщика.ПараметрыВывода.Элементы.Найти("ТипДиаграммы");
	
	Если СвойстваДиаграммы <> Неопределено Тогда
		//Переберем свойства
		СвойствоОтображатьЛегенду = СвойстваДиаграммы.ЗначенияВложенныхПараметров.Найти("ТипДиаграммы.РасположениеЛегенды");
		
		Если СвойствоОтображатьЛегенду <> Неопределено Тогда
			Если СвойствоОтображатьЛегенду.Использование Тогда
				Если СвойствоОтображатьЛегенду.Значение <> РасположениеЛегендыДиаграммыКомпоновкиДанных.Нет Тогда
					Диаграмма.ОтображатьЛегенду = Истина;
				Иначе
					Диаграмма.ОтображатьЛегенду = Ложь;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		СвойствоШрифт = СвойстваДиаграммы.ЗначенияВложенныхПараметров.Найти("ТипДиаграммы.Шрифт");
		
		Если СвойствоШрифт <> Неопределено Тогда
			Если СвойствоШрифт.Использование Тогда
				Диаграмма.ОбластьПостроения.Шрифт = Новый Шрифт(СвойствоШрифт.Значение);
				Диаграмма.ОбластьЛегенды.Шрифт = Новый Шрифт(СвойствоШрифт.Значение);
			КонецЕсли;
		КонецЕсли;
		
		СвойствоПолосыИзмерительнойДиаграммы = СвойстваДиаграммы.ЗначенияВложенныхПараметров.Найти("ТипДиаграммы.ПолосыИзмерительнойДиаграммы");
		
		Если СвойствоПолосыИзмерительнойДиаграммы <> Неопределено Тогда
			Если СвойствоПолосыИзмерительнойДиаграммы.Использование Тогда
				Для Каждого Полосочка Из СвойствоПолосыИзмерительнойДиаграммы.Значение Цикл
					НоваяПолосочка = Диаграмма.ПолосыИзмерительнойДиаграммы.Добавить();
					
					ЗаполнитьЗначенияСвойств(НоваяПолосочка, Полосочка);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	СвойствоЗаголовок = НастройкиКомпоновщика.ПараметрыВывода.Элементы.Найти("ВыводитьЗаголовок");
	
	Если СвойствоЗаголовок <> Неопределено Тогда
		Если СвойствоЗаголовок.Использование Тогда
			Если СвойствоЗаголовок.Значение = ТипВыводаТекстаКомпоновкиДанных.НеВыводить Тогда
				Диаграмма.ОтображатьЗаголовок = Ложь;
			Иначе
				Диаграмма.ОтображатьЗаголовок = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Для Каждого Серия Из Рисунок.Серии Цикл
		НоваяСерия = Диаграмма.Серии.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСерия, Серия);
		
		НоваяСерия.Маркер = ТипМаркераДиаграммы.Нет;
	КонецЦикла;
	
	Для Каждого Точка Из Рисунок.Точки Цикл
		НоваяТочка = Диаграмма.Точки.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяТочка, Точка);
	КонецЦикла;
	
	Для Каждого Серия Из Рисунок.Серии Цикл
		Для Каждого Точка Из Рисунок.Точки Цикл
			Значение = Рисунок.ПолучитьЗначение(Точка, Серия);
			
			ИндексСерии = Рисунок.Серии.Индекс(Серия);
			ИндексТочки = Рисунок.Точки.Индекс(Точка);
			
			Диаграмма.УстановитьЗначение(ИндексТочки, ИндексСерии, Значение.Значение, Значение.Расшифровка, Значение.Подсказка);
		КонецЦикла;
	КонецЦикла;
	
	Диаграмма.Обновление = Истина;
	
	Возврат Диаграмма;
	
КонецФункции

#КонецОбласти


#Область ПрограммныйИнтерфейс

Функция бит_омни_ДанныеДокументов(HTTPЗапрос) Экспорт
	
	ТипПоиска = HTTPЗапрос.ПараметрыЗапроса.Получить("search_type");
	
	Если ТипПоиска = Неопределено Тогда
		Возврат бит_омни_ИнтеграцияСерверСлужебный.НеопределенТипПоиска();	
	ИначеЕсли ТипПоиска = "ByPatient" Тогда                                     
		ИдентификаторПациента = HTTPЗапрос.ПараметрыЗапроса.Получить("patient_id");
		Возврат бит_омни_АнкетыПоПациенту(ИдентификаторПациента);
	ИначеЕсли ТипПоиска = "ByID" Тогда
		ИдентификаторАнкеты = HTTPЗапрос.ПараметрыЗапроса.Получить("surveyId");
		Возврат бит_омни_АнкетаПоUUID(ИдентификаторАнкеты);
	Иначе	
		Возврат бит_омни_ИнтеграцияСерверСлужебный.НеверныйТипПоиска();	
	КонецЕсли;

КонецФункции

Функция бит_омни_ОбновитьДокумент(HTTPЗапрос) Экспорт

	ТелоЗапроса = бит_омни_ИнтеграцияСервер.ТелоЗапросаВСтруктуру(HTTPЗапрос);
	ИдентификаторДокумента = Неопределено;
	ТелоЗапроса.Свойство("surveyId", ИдентификаторДокумента);
	
	Анкета = бит_омни_АнкетаПоUUID(ИдентификаторДокумента, Истина);
	
	Если ТипЗнч(Анкета) <> Тип("ДокументСсылка.Анкета") Тогда
		Возврат Анкета; // функция может вернуть только HTTPСервисОтвет или ДокументСсылка.Анкета
	КонецЕсли;
	
	СоставАнкеты = Неопределено;
	ТелоЗапроса.Свойство("surveyItems", СоставАнкеты);
	Если СоставАнкеты = Неопределено Тогда
		Возврат бит_омни_ОтсутствуетСоставАнкеты();
	КонецЕсли;
	
	Если ТипЗнч(СоставАнкеты) <> Тип("Массив")
		Или СоставАнкеты.Количество() = 0 Тогда
		Возврат бит_омни_ОтсутствуетСоставАнкеты();
	КонецЕсли;
	
	АнкетаОбъект = Анкета.ПолучитьОбъект();
	ВопросыШаблона = бит_омни_ВопросыШаблонаАнкеты(АнкетаОбъект.ШаблонАнкеты);
	
	АнкетаОбъект.Состав.Очистить();
	
	Индекс = 0;
	Для Каждого ЭлементСостава Из СоставАнкеты Цикл
		
		ИдентификаторВопроса = бит_омни_ЗначениеСвойстваJSON(ЭлементСостава, "questionId");
		ИмяПоляВопроса = СтрШаблон("surveyItems[%1].questionId", Формат(Индекс, "ЧГ="));
		РезультатПроверки = бит_омни_ИнтеграцияСервер.ВалидироватьИдентификатор(ИдентификаторВопроса, ИмяПоляВопроса);
		Если РезультатПроверки <> Неопределено Тогда
			Возврат РезультатПроверки;
		КонецЕсли;
		
		UUIDВопроса = Новый УникальныйИдентификатор(ИдентификаторВопроса);
		ДанныеВопроса = ВопросыШаблона.Получить(UUIDВопроса);
		Если ДанныеВопроса = Неопределено Тогда
			Возврат бит_омни_ВопросНеИзШаблонаАнкеты(ИмяПоляВопроса);
		КонецЕсли;
		
		Ответ = бит_омни_ОтветИзДанныхЗапроса(ЭлементСостава, ДанныеВопроса, Индекс);
		Если ТипЗнч(Ответ) = Тип("HTTPСервисОтвет") Тогда
			Возврат Ответ;
		КонецЕсли;
		
		СтрокаСостава = АнкетаОбъект.Состав.Добавить();
		СтрокаСостава.Вопрос = ДанныеВопроса.Вопрос;
		СтрокаСостава.ОткрытыйОтвет = бит_омни_ЗначениеСвойстваJSON(ЭлементСостава, "openAnswer", "");
		СтрокаСостава.НомерЯчейки = бит_омни_ЗначениеСвойстваJSON(ЭлементСостава, "numberAnswer", 0);
		СтрокаСостава.Ответ = Ответ;
		
		Индекс = Индекс + 1;
	КонецЦикла;
	
	ПровестиАнкету = бит_омни_ЗначениеСвойстваJSON(ТелоЗапроса, "isDone", Ложь);
	РежимЗаписи = ?(ПровестиАнкету, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись);
	
	Попытка
		АнкетаОбъект.Записать(РежимЗаписи);
	Исключение
		Ошибки = Новый Массив;
		Ошибки.Добавить(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		Сообщения = ПолучитьСообщенияПользователю(Истина);
		Для Каждого Сообщение Из Сообщения Цикл
			Ошибки.Добавить(Сообщение.Текст);
		КонецЦикла;
		
		Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой("couldnt_update_survey", 400, СтрСоединить(Ошибки, Символы.ПС));
	КонецПопытки;
	
	Возврат бит_омни_АнкетаПоUUID(Строка(Анкета.УникальныйИдентификатор()));

КонецФункции


#КонецОбласти

Функция бит_омни_АнкетаПоUUID(Знач ИдентификаторДокумента, ВернутьСсылку = Ложь) Экспорт

	РезультатПроверки = бит_омни_ИнтеграцияСервер.ВалидироватьИдентификатор(ИдентификаторДокумента, "surveyId");
	
	Если РезультатПроверки <> Неопределено Тогда
		Возврат РезультатПроверки;
	КонецЕсли;
	
	Анкета = ПолучитьСсылку(ИдентификаторДокумента);
	Если НЕ ОбщегоНазначения.СсылкаСуществует(Анкета) Тогда
		Возврат бит_омни_НеНайденаАнкета();
	КонецЕсли;
	
	Если ВернутьСсылку Тогда
		Возврат Анкета;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Анкета.Ссылка)) КАК surveyId,
	|	Анкета.Дата КАК surveyDate,
	|	Анкета.Проведен КАК isDone,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Анкета.ШаблонАнкеты)) КАК surveyTemplateId,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Анкета.ШаблонАнкеты) КАК surveyTemplateTitle,
	|	АнкетаСостав.НомерСтроки КАК numberQuestion,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(АнкетаСостав.Вопрос)) КАК questionId,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(АнкетаСостав.Вопрос) КАК questionTitle,
	|	АнкетаСостав.ОткрытыйОтвет КАК openAnswer,
	|	АнкетаСостав.НомерЯчейки КАК numberAnswer,
	|	ВЫБОР
	|		КОГДА АнкетаСостав.Ответ ССЫЛКА Справочник.ВариантыОтветовАнкет
	|				ИЛИ АнкетаСостав.Ответ ССЫЛКА Справочник.Филиалы
	|				ИЛИ АнкетаСостав.Ответ ССЫЛКА Справочник.КатегорииВыработки
	|				ИЛИ АнкетаСостав.Ответ ССЫЛКА Справочник.Сотрудники
	|				ИЛИ АнкетаСостав.Ответ ССЫЛКА Перечисление.ПолФизическихЛиц
	|			ТОГДА ПРЕДСТАВЛЕНИЕССЫЛКИ(АнкетаСостав.Ответ)
	|		ИНАЧЕ АнкетаСостав.Ответ
	|	КОНЕЦ КАК answerTitle,
	|	ВЫБОР
	|		КОГДА АнкетаСостав.Ответ ССЫЛКА Справочник.ВариантыОтветовАнкет
	|			ТОГДА ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ВЫРАЗИТЬ(АнкетаСостав.Ответ КАК Справочник.ВариантыОтветовАнкет)))
	|		КОГДА АнкетаСостав.Ответ ССЫЛКА Справочник.Филиалы
	|			ТОГДА ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ВЫРАЗИТЬ(АнкетаСостав.Ответ КАК Справочник.Филиалы)))
	|		КОГДА АнкетаСостав.Ответ ССЫЛКА Справочник.КатегорииВыработки
	|			ТОГДА ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ВЫРАЗИТЬ(АнкетаСостав.Ответ КАК Справочник.КатегорииВыработки)))
	|		КОГДА АнкетаСостав.Ответ ССЫЛКА Справочник.Сотрудники
	|			ТОГДА ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ВЫРАЗИТЬ(АнкетаСостав.Ответ КАК Справочник.Сотрудники)))
	|		КОГДА АнкетаСостав.Ответ ССЫЛКА Перечисление.ПолФизическихЛиц
	|			ТОГДА ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ВЫРАЗИТЬ(АнкетаСостав.Ответ КАК Перечисление.ПолФизическихЛиц)))
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК answerId
	|ИЗ
	|	Документ.Анкета.Состав КАК АнкетаСостав
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Анкета КАК Анкета
	|		ПО АнкетаСостав.Ссылка = Анкета.Ссылка
	|ГДЕ
	|	Анкета.Ссылка = &Анкета
	|
	|УПОРЯДОЧИТЬ ПО
	|	surveyDate УБЫВ
	|ИТОГИ ПО
	|	Анкета.Ссылка";
	
	Запрос.УстановитьПараметр("Анкета", Анкета);
	РезультатЗапроса = Запрос.Выполнить();
		
	ТелоОтвета = Новый Массив;
	ВыборкаАнкеты = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаАнкеты.Следующий() Цикл
		ДанныеАнкеты = Новый Структура("surveyId, surveyDate, isDone, surveyTemplateId, surveyTemplateTitle, surveyItems");
		ЗаполнитьЗначенияСвойств(ДанныеАнкеты, ВыборкаАнкеты);
		ДанныеАнкеты.surveyItems = Новый Массив;
		
		ВыборкаСоставАнкеты = ВыборкаАнкеты.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаСоставАнкеты.Следующий() Цикл
			СоставАнкеты = Новый Структура("numberQuestion, questionId, questionTitle, openAnswer, numberAnswer, answerTitle, answerId");
			ЗаполнитьЗначенияСвойств(СоставАнкеты, ВыборкаСоставАнкеты);
			ДанныеАнкеты.surveyItems.Добавить(СоставАнкеты)
		КонецЦикла;
		ТелоОтвета.Добавить(ДанныеАнкеты);
	КонецЦикла; 
	
	Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(ДанныеАнкеты);

КонецФункции

Функция бит_омни_НеНайденаАнкета()

	Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой("survey_not_found", 404);

КонецФункции

Функция бит_омни_ОтсутствуетСоставАнкеты()

	Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой("surveyItems_required");

КонецФункции

Функция бит_омни_ВопросНеИзШаблонаАнкеты(ИмяПоля)

	Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой(СтрШаблон("invalid_%1", ИмяПоля));

КонецФункции

Функция бит_омни_ОтветНеНайден(ИмяПоля)

	Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой(СтрШаблон("invalid_%1", ИмяПоля));

КонецФункции

Функция бит_омни_ВопросыШаблонаАнкеты(ШаблонАнкеты)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ВопросыШаблонаАнкеты.Ссылка) КАК ИдентификаторВопроса,
	|	ВопросыШаблонаАнкеты.Ссылка КАК Вопрос,
	|	ВопросыШаблонаАнкеты.ЭлементарныйВопрос КАК ЭлементарныйВопрос,
	|	ВопросыДляАнкетирования.ТипЗначения КАК ТипЗначения
	|ИЗ
	|	Справочник.ВопросыШаблонаАнкеты КАК ВопросыШаблонаАнкеты
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовХарактеристик.ВопросыДляАнкетирования КАК ВопросыДляАнкетирования
	|		ПО ВопросыШаблонаАнкеты.ЭлементарныйВопрос = ВопросыДляАнкетирования.Ссылка
	|ГДЕ
	|	ВопросыШаблонаАнкеты.Владелец = &ШаблонАнкеты
	|	И НЕ ВопросыШаблонаАнкеты.ЭтоГруппа
	|	И НЕ ВопросыШаблонаАнкеты.ПометкаУдаления";
	Запрос.УстановитьПараметр("ШаблонАнкеты", ШаблонАнкеты);
	
	ВопросыШаблона = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ВопросыШаблона.Вставить(
			Выборка.ИдентификаторВопроса,
			Новый Структура("Вопрос, ЭлементарныйВопрос, ТипЗначения", Выборка.Вопрос, Выборка.ЭлементарныйВопрос, Выборка.ТипЗначения));
	КонецЦикла;
	
	Возврат ВопросыШаблона;
	
КонецФункции

Функция бит_омни_ОтветИзДанныхЗапроса(ЭлементСостава, ДанныеВопроса, Индекс)
	
	ИдентификаторОтвета = бит_омни_ЗначениеСвойстваJSON(ЭлементСостава, "answerId");
	Если ЗначениеЗаполнено(ИдентификаторОтвета) Тогда
		ИмяПоляОтвета = СтрШаблон("surveyItems[%1].answerId", Формат(Индекс, "ЧГ="));
		РезультатПроверки = бит_омни_ИнтеграцияСервер.ВалидироватьИдентификатор(ИдентификаторОтвета, ИмяПоляОтвета);
		Если РезультатПроверки <> Неопределено Тогда
			Возврат РезультатПроверки;
		КонецЕсли;
		
		Ответ = бит_омни_ОтветПоUUID(Новый УникальныйИдентификатор(ИдентификаторОтвета), ДанныеВопроса);
		Если Ответ = Неопределено Тогда
			Возврат бит_омни_ОтветНеНайден(ИмяПоляОтвета);
		КонецЕсли;
		
		Возврат Ответ;
	КонецЕсли;
	
	Ответ = бит_омни_ЗначениеСвойстваJSON(ЭлементСостава, "answerTitle");
	Если ТипЗнч(ДанныеВопроса.ТипЗначения) = Тип("ОписаниеТипов") Тогда
		Ответ = ДанныеВопроса.ТипЗначения.ПривестиЗначение(Ответ);
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

Функция бит_омни_ОтветПоUUID(UUIDОтвета, ДанныеВопроса)
	
	МенеджерыОтветов = Новый Массив;
	МенеджерыОтветов.Добавить(Справочники.ВариантыОтветовАнкет);
	МенеджерыОтветов.Добавить(Справочники.Филиалы);
	МенеджерыОтветов.Добавить(Справочники.КатегорииВыработки);
	МенеджерыОтветов.Добавить(Справочники.Сотрудники);
	МенеджерыОтветов.Добавить(Перечисления.ПолФизическихЛиц);
	
	Для Каждого МенеджерОтветов Из МенеджерыОтветов Цикл
		Попытка
			Ответ = МенеджерОтветов.ПолучитьСсылку(UUIDОтвета);
		Исключение
			Продолжить;
		КонецПопытки;
		
		Если НЕ бит_омни_СсылкаОтветаСуществует(Ответ) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(Ответ) = Тип("СправочникСсылка.ВариантыОтветовАнкет") Тогда
			ВладелецОтвета = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ответ, "Владелец");
			Если ВладелецОтвета <> ДанныеВопроса.ЭлементарныйВопрос Тогда
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		Если ТипЗнч(ДанныеВопроса.ТипЗначения) = Тип("ОписаниеТипов")
			И Не ДанныеВопроса.ТипЗначения.СодержитТип(ТипЗнч(Ответ)) Тогда
			Продолжить;
		КонецЕсли;
		
		Возврат Ответ;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

Функция бит_омни_СсылкаОтветаСуществует(Ответ)
	
	Попытка
		Возврат ОбщегоНазначения.СсылкаСуществует(Ответ);
	Исключение
		Возврат ЗначениеЗаполнено(Ответ);
	КонецПопытки;
	
КонецФункции

Функция бит_омни_ЗначениеСвойстваJSON(ДанныеJSON, ИмяСвойства, ЗначениеПоУмолчанию = Неопределено)
	
	ЗначениеСвойства = ЗначениеПоУмолчанию;
	Если ДанныеJSON <> Неопределено Тогда
		ДанныеJSON.Свойство(ИмяСвойства, ЗначениеСвойства);
	КонецЕсли;
	
	Возврат ЗначениеСвойства;
	
КонецФункции


Функция бит_омни_АнкетыПоПациенту(ИдентификаторПациента)

	Если ИдентификаторПациента = Неопределено Тогда
		Возврат Справочники.Клиенты.бит_омни_НеопределенИдентификатор();
	КонецЕсли;	                                                        
	
	Клиент = Справочники.Клиенты.бит_омни_ПациентПоUUID(ИдентификаторПациента, Истина);
	
	Если ТипЗнч(Клиент) <> Тип("СправочникСсылка.Клиенты") Тогда
		Возврат Клиент; // функция может вернуть только HTTPСервисОтвет или СправочникСсылка.Клиенты
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 100
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Анкета.Ссылка)) КАК surveyId,
	|	Анкета.Дата КАК surveyDate,
	|	Анкета.Проведен КАК isDone,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Анкета.ШаблонАнкеты)) КАК surveyTemplateId,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Анкета.ШаблонАнкеты) КАК surveyTemplateTitle
	|ИЗ
	|	Документ.Анкета КАК Анкета
	|ГДЕ
	|	Анкета.Респондент = &Клиент
	|	И НЕ Анкета.ПометкаУдаления
	|
	|УПОРЯДОЧИТЬ ПО
	|	surveyDate УБЫВ";
	
	Запрос.УстановитьПараметр("Клиент", Клиент);
	РезультатЗапроса = Запрос.Выполнить();
	
	ДанныеЗапроса = РезультатЗапроса.Выгрузить();
	
	ТелоОтвета = ОбщегоНазначения.ТаблицаЗначенийВМассив(ДанныеЗапроса);                            
	
	Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(ТелоОтвета);

КонецФункции

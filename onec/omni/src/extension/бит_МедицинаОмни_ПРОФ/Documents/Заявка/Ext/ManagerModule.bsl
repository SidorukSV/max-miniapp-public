Функция бит_омни_ПолучитьДанныеЗаявок(ПараметрыПоиска, УсловиеПоиска, Лимит = Неопределено)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	&Лимит КАК Лимит,
	|	ВЫБОР
	|		КОГДА ЗаявкаРаботы.Сотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|			ТОГДА Заявка.Сотрудник
	|		ИНАЧЕ ЗаявкаРаботы.Сотрудник
	|	КОНЕЦ КАК Врач,
	|	ЗаявкаРаботы.ДатаНачала КАК ВремяНачала,
	|	ЗаявкаРаботы.Ссылка КАК Ссылка,
	|	НАЧАЛОПЕРИОДА(ЗаявкаРаботы.Ссылка.ДатаНачала, ДЕНЬ) КАК Дата,
	|	Заявка.Клиент КАК Клиент,
	|	ВЫБОР
	|		КОГДА ЗаявкаРаботы.Оборудование1 <> ЗНАЧЕНИЕ(Справочник.Оборудование.ПустаяСсылка)
	|			ТОГДА ЗаявкаРаботы.Оборудование1
	|		ИНАЧЕ Заявка.Кабинет
	|	КОНЕЦ КАК Кабинет,
	|	ЗаявкаРаботы.Номенклатура КАК Номенклатура,
	|	Заявка.Филиал КАК Филиал,
	|	Заявка.Состояние КАК Состояние,
	|	&Подтверждена КАК Подтверждена
	|ПОМЕСТИТЬ ДанныеПоЗаявкам
	|ИЗ
	|	Документ.Заявка.Работы КАК ЗаявкаРаботы
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Заявка КАК Заявка
	|		ПО ЗаявкаРаботы.Ссылка = Заявка.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЗначенияСвойствОбъектов КАК ЗначенияСвойствОбъектов
	|		ПО &УсловиеСвязиСвойстваОбъектов
	|ГДЕ
	|	&ТекстУсловия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ДанныеПоЗаявкам.Врач)) КАК doctorId,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ДанныеПоЗаявкам.Врач) КАК doctorTitle,
	|	СпрСотрудники.Фамилия КАК doctorLastname,
	|	СпрСотрудники.Имя КАК doctorFirstname,
	|	СпрСотрудники.Отчество КАК doctorPatronimic,
	|	ДанныеПоЗаявкам.ВремяНачала КАК datetimeBegin,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ДанныеПоЗаявкам.Ссылка)) КАК appointment_id,
	|	ДанныеПоЗаявкам.Дата КАК appointment_date,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ДанныеПоЗаявкам.Клиент)) КАК patient_id,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ДанныеПоЗаявкам.Кабинет)) КАК cabinetId,
	|	ВЫБОР
	|		КОГДА ДанныеПоЗаявкам.Кабинет = ЗНАЧЕНИЕ(Справочник.Оборудование.ПустаяСсылка)
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ПРЕДСТАВЛЕНИЕССЫЛКИ(ДанныеПоЗаявкам.Кабинет)
	|	КОНЕЦ КАК cabinetTitle,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ДанныеПоЗаявкам.Номенклатура)) КАК serviceId,
	|	ВЫБОР
	|		КОГДА ДанныеПоЗаявкам.Номенклатура = ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|			ТОГДА НЕОПРЕДЕЛЕНО
	|		ИНАЧЕ ПРЕДСТАВЛЕНИЕССЫЛКИ(ДанныеПоЗаявкам.Номенклатура)
	|	КОНЕЦ КАК serviceTitle,
	|	ВЫБОР
	|		КОГДА ДанныеПоЗаявкам.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|			ТОГДА ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СпрНоменклатура.КатегорияВыработки))
	|		ИНАЧЕ ЕСТЬNULL(ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(СпрСотрудники.Специализация)), ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ЗНАЧЕНИЕ(Справочник.КатегорииВыработки.ПустаяСсылка))))
	|	КОНЕЦ КАК specializationId,
	|	ВЫБОР
	|		КОГДА ДанныеПоЗаявкам.Номенклатура <> ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)
	|			ТОГДА ПРЕДСТАВЛЕНИЕССЫЛКИ(СпрНоменклатура.КатегорияВыработки)
	|		ИНАЧЕ ЕСТЬNULL(ПРЕДСТАВЛЕНИЕССЫЛКИ(СпрСотрудники.Специализация), НЕОПРЕДЕЛЕНО)
	|	КОНЕЦ КАК specializationTitle,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ДанныеПоЗаявкам.Филиал)) КАК branchId,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ДанныеПоЗаявкам.Филиал) КАК branchTitle,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(ВидыСостоянийЗаявок.бит_омни_ЗаголовокДляВыгрузки, """") <> """"
	|			ТОГДА ВидыСостоянийЗаявок.бит_омни_ЗаголовокДляВыгрузки
	|		КОГДА ЕСТЬNULL(ВидыСостоянийЗаявок.ИмяПредопределенныхДанных, """") <> """"
	|			ТОГДА ВидыСостоянийЗаявок.ИмяПредопределенныхДанных
	|		ИНАЧЕ ПРЕДСТАВЛЕНИЕССЫЛКИ(ДанныеПоЗаявкам.Состояние)
	|	КОНЕЦ КАК conditionTitle,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ДанныеПоЗаявкам.Состояние)) КАК conditionId,
	|	ДанныеПоЗаявкам.Подтверждена КАК isApproved
	|ИЗ
	|	ДанныеПоЗаявкам КАК ДанныеПоЗаявкам
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК СпрСотрудники
	|		ПО ДанныеПоЗаявкам.Врач = СпрСотрудники.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СпрНоменклатура
	|		ПО ДанныеПоЗаявкам.Номенклатура = СпрНоменклатура.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыСостоянийЗаявок КАК ВидыСостоянийЗаявок
	|		ПО ДанныеПоЗаявкам.Состояние = ВидыСостоянийЗаявок.Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	datetimeBegin";
	
	Если ЗначениеЗаполнено(УсловиеПоиска) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ТекстУсловия", УсловиеПоиска);
	Иначе
		Запрос.УстановитьПараметр("ТекстУсловия", Истина);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Лимит) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Лимит КАК Лимит,", СтрШаблон("ПЕРВЫЕ %1", Формат(Лимит, "ЧГ=")));
	КонецЕсли;
	
	ПризнакПодтвержденнойЗаявки = УправлениеНастройками.ПолучитьПараметрУчетнойПолитики("ПризнакПодтвержденнойЗаявки");
	Если НЕ ЗначениеЗаполнено(ПризнакПодтвержденнойЗаявки) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Подтверждена", "Неопределено");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСвязиСвойстваОбъектов", "ЛОЖЬ");
	ИначеЕсли ТипЗнч(ПризнакПодтвержденнойЗаявки) = Тип("СправочникСсылка.ВидыСостоянийЗаявок") Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Подтверждена", "Заявка.Состояние = &СостояниеПодтверждена");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСвязиСвойстваОбъектов", "ЛОЖЬ");
		Запрос.УстановитьПараметр("СостояниеПодтверждена", ПризнакПодтвержденнойЗаявки);
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&Подтверждена", "ЗначенияСвойствОбъектов.Значение = ИСТИНА");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСвязиСвойстваОбъектов", 
			"ЗаявкаРаботы.Ссылка = ЗначенияСвойствОбъектов.Объект
			|	И ЗначенияСвойствОбъектов.Свойство = &СвойствоПодтверждена");
		Запрос.УстановитьПараметр("СвойствоПодтверждена", ПризнакПодтвержденнойЗаявки);
	КонецЕсли;
	
	Для Каждого ПараметрПоиска Из ПараметрыПоиска Цикл
		Запрос.УстановитьПараметр(ПараметрПоиска.Ключ, ПараметрПоиска.Значение);
	КонецЦикла;
	
	РезультатЗапроса = Запрос.Выполнить();
	ДанныеИзЗапроса = РезультатЗапроса.Выгрузить();
	Возврат ДанныеИзЗапроса;

КонецФункции

Функция бит_омни_ПодтвердитьЗаявку(Заявка, ИдентификаторДокумента)
	
	ПризнакПодтвержденнойЗаявки = УправлениеНастройками.ПолучитьПараметрУчетнойПолитики("ПризнакПодтвержденнойЗаявки");
	Если НЕ ЗначениеЗаполнено(ПризнакПодтвержденнойЗаявки) Тогда
		Возврат бит_омни_ПодтверждениеЗаписиНедоступно();		
	КонецЕсли;
	
	ТелоЗапроса = Новый Структура("appointmentId, isApproved", ИдентификаторДокумента, Истина);
	Попытка
		бит_омни_ЗаписатьПодтверждениеЗаявки(Заявка, ПризнакПодтвержденнойЗаявки);
	Исключение                                          
		Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой("couldnt_approve", 500, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
	Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(ТелоЗапроса);
	
КонецФункции

Процедура бит_омни_ЗаписатьПодтверждениеЗаявки(Заявка, ПризнакПодтвержденнойЗаявки = Неопределено)
	
	ПризнакПодтвержденнойЗаявки = УправлениеНастройками.ПолучитьПараметрУчетнойПолитики("ПризнакПодтвержденнойЗаявки");
	Если НЕ ЗначениеЗаполнено(ПризнакПодтвержденнойЗаявки) Тогда
		Возврат;		
	КонецЕсли;
	
	Если ТипЗнч(ПризнакПодтвержденнойЗаявки) = Тип("СправочникСсылка.ВидыСостоянийЗаявок") Тогда
		ЗаявкаОбъект = Заявка.ПолучитьОбъект();
		ЗаявкаОбъект.Состояние = ПризнакПодтвержденнойЗаявки;
		ЗаявкаОбъект.Записать();
	Иначе
		Запись = РегистрыСведений.ЗначенияСвойствОбъектов.СоздатьМенеджерЗаписи();
		Запись.Объект	= Заявка;
		Запись.Свойство	= ПризнакПодтвержденнойЗаявки;
		Запись.Значение = Истина;
		Запись.Записать();
	КонецЕсли;

КонецПроцедуры

Функция бит_омни_ОтменитьЗаявку(Заявка, ИдентификаторДокумента)
	
	ПризнакПодтвержденнойЗаявки = УправлениеНастройками.ПолучитьПараметрУчетнойПолитики("ПризнакПодтвержденнойЗаявки");
	Если НЕ ЗначениеЗаполнено(ПризнакПодтвержденнойЗаявки) Тогда
		Возврат бит_омни_ПодтверждениеЗаписиНедоступно();		
	КонецЕсли;
	
	ТелоЗапроса = Новый Структура("appointmentId, isCanceled", ИдентификаторДокумента, Истина);
	
	Попытка
		ЗаявкаОбъект = Заявка.ПолучитьОбъект();
		ЗаявкаОбъект.ОтменитьЗаявку(Ложь);
	Исключение                                          
		Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой("couldnt_approve", 500, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	 	
	Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(ТелоЗапроса);
	
КонецФункции

#КонецОбласти

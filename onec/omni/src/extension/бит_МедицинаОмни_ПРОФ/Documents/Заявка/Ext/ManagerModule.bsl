#Область ПрограммныйИнтерфейс

Функция бит_омни_ДанныеДокументов(HTTPЗапрос) Экспорт
	
	ТипПоиска = HTTPЗапрос.ПараметрыЗапроса.Получить("search_type");
	
	Если ТипПоиска = Неопределено Тогда
		Возврат бит_омни_ИнтеграцияСерверСлужебный.НеопределенТипПоиска();	
	ИначеЕсли ТипПоиска = "ByPatient" Тогда                                     
		ИдентификаторПациента = HTTPЗапрос.ПараметрыЗапроса.Получить("patient_id");
		Возврат бит_омни_ЗаявкиПоПациенту(ИдентификаторПациента);
	ИначеЕсли ТипПоиска = "ByID" Тогда
		ИдентификаторПациента = HTTPЗапрос.ПараметрыЗапроса.Получить("appointmentId");
		Возврат бит_омни_ЗаявкаПоUUID(ИдентификаторПациента);
	Иначе	
		Возврат бит_омни_ИнтеграцияСерверСлужебный.НеверныйТипПоиска();	
	КонецЕсли;

КонецФункции

Функция бит_омни_ОбновитьДокумент(HTTPЗапрос) Экспорт

	ТелоЗапроса = бит_омни_ИнтеграцияСервер.ТелоЗапросаВСтруктуру(HTTPЗапрос);
	ИдентификаторДокумента = Неопределено;
	ТелоЗапроса.Свойство("appointmentId", ИдентификаторДокумента);
	
	Заявка = бит_омни_ЗаявкаПоUUID(ИдентификаторДокумента, Истина);
	
	Если ТипЗнч(Заявка) <> Тип("ДокументСсылка.Заявка") Тогда
		Возврат Заявка; // функция может вернуть только HTTPСервисОтвет или ДокументСсылка.Заявка
	КонецЕсли;
	
	Если ТелоЗапроса.Свойство("isApproved") Тогда
		Возврат бит_омни_ПодтвердитьЗаявку(Заявка, ИдентификаторДокумента);	
	КонецЕсли;
	
	Если ТелоЗапроса.Свойство("isCanceled") Тогда
		Возврат бит_омни_ОтменитьЗаявку(Заявка, ИдентификаторДокумента);	
	КонецЕсли;
	
	Возврат бит_омни_СоздатьОбновитьДокумент(HTTPЗапрос, Истина); 

КонецФункции

Функция бит_омни_СоздатьДокумент(HTTPЗапрос) Экспорт
	
	Возврат бит_омни_СоздатьОбновитьДокумент(HTTPЗапрос);  
	
КонецФункции // бит_омни_СоздатьДокумент()


#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция бит_омни_СоздатьОбновитьДокумент(HTTPЗапрос, Обновление = Ложь)

	ТелоЗапроса = бит_омни_ИнтеграцияСервер.ТелоЗапросаВСтруктуру(HTTPЗапрос);
	
	Клиент = Справочники.Клиенты.бит_омни_ПациентПоUUID(ТелоЗапроса.patient_id, Истина);
	
	Если ТипЗнч(Клиент) <> Тип("СправочникСсылка.Клиенты") Тогда
		Возврат Клиент; // если тип другой, то это HTTPСервисОтвет	
	КонецЕсли;
	
	Сотрудник = Справочники.Сотрудники.бит_омни_СотрудникПоUUID(ТелоЗапроса.doctorId, Истина);
	
	Если ТипЗнч(Сотрудник) <> Тип("СправочникСсылка.Сотрудники") Тогда
		Возврат Сотрудник; // если тип другой, то это HTTPСервисОтвет	
	КонецЕсли;
	
	Филиал = Справочники.Филиалы.бит_омни_ФилиалПоUUID(ТелоЗапроса.branchId, Истина);
	
	Если ТипЗнч(Филиал) <> Тип("СправочникСсылка.Филиалы") Тогда
		Возврат Филиал; // если тип другой, то это HTTPСервисОтвет	
	КонецЕсли;
	
	Специализация = Справочники.КатегорииВыработки.бит_омни_СпециализацияПоUUID(ТелоЗапроса.specializationId, Истина);
	
	Если ТипЗнч(Специализация) <> Тип("СправочникСсылка.КатегорииВыработки") Тогда
		Возврат Специализация; // если тип другой, то это HTTPСервисОтвет	
	КонецЕсли;
	
	Кабинет = Справочники.Оборудование.бит_омни_ОборудованиеПоUUID(ТелоЗапроса.cabinetId, Истина);
	
	Если ТипЗнч(Кабинет) <> Тип("СправочникСсылка.Оборудование") Тогда
		Кабинет = Справочники.Оборудование.ПустаяСсылка(); // необязательное поле	
	КонецЕсли;

	ДатаНачала = ТелоЗапроса.datetimeBegin;
	РезультатПроверки = бит_омни_ИнтеграцияСервер.ВалидироватьДату(ДатаНачала, "datetimeBegin", Истина);
	
	Если РезультатПроверки <> Неопределено Тогда
		Возврат РезультатПроверки;	
	КонецЕсли;
	
	ДлительностьПриема = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сотрудник, "ДлительностьПриема");
	ДлительностьПриемааВСекундах = ОбщегоНазначения.ВремяВСекунды(ДлительностьПриема);
	
	Если Обновление Тогда
		ЗаявкаСсылка = бит_омни_ЗаявкаПоUUID(ТелоЗапроса.appointmentId, Истина);
		
		Если ТипЗнч(ЗаявкаСсылка) <> Тип("ДокументСсылка.Заявка") Тогда
			Возврат ЗаявкаСсылка; // если тип другой, то это HTTPСервисОтвет	
		КонецЕсли;
		
		Заявка = ЗаявкаСсылка.ПолучитьОбъект(); 
		Заявка.Работы.Очистить();
	Иначе
		Заявка = Документы.Заявка.СоздатьДокумент();
		Заявка.Дата = ТекущаяДатаСеанса();
		Заявка.Клиент = Клиент;
		Заявка.Кабинет = Кабинет;
		Заявка.бит_омни_Специализация = Специализация;
		Заявка.Состояние = Справочники.ВидыСостоянийЗаявок.Запланирована;
	КонецЕсли;
	
	Заявка.Сотрудник = Сотрудник;
	Заявка.Филиал = Филиал;
	Заявка.ДатаНачала = ДатаНачала;
	Заявка.ВремяНачала = ДатаНачала;
	Заявка.ДатаОкончания = ДатаНачала + ДлительностьПриемааВСекундах;
	Заявка.ВремяОкончания = Заявка.ДатаОкончания;
	ЗаявкаРаботы = Заявка.Работы.Добавить();
	ЗаявкаРаботы.ДатаНачала = Заявка.ДатаНачала;
	ЗаявкаРаботы.ДатаОкончания = Заявка.ДатаОкончания;
	ЗаявкаРаботы.Продолжительность = Дата(1,1,1) + (Заявка.ДатаОкончания - Заявка.ДатаНачала);
	
	Попытка
		Заявка.Записать();
		
		Если НЕ Обновление Тогда
			бит_омни_ЗаписатьПодтверждениеЗаявки(Заявка.Ссылка);
		КонецЕсли;
		
		Возврат бит_омни_ЗаявкаПоUUID(Строка(Заявка.Ссылка.УникальныйИдентификатор()));
	Исключение
		Ошибки = Новый Массив;
		Ошибки.Добавить(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		Сообщения = ПолучитьСообщенияПользователю(Истина);
		Для Каждого Сообщение Из Сообщения Цикл
			Ошибки.Добавить(Сообщение.Текст);
		КонецЦикла;
		
		Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой("couldnt_appointment", 400, СтрСоединить(Ошибки, Символы.ПС));
	КонецПопытки;

КонецФункции // бит_омни_СоздатьОбновитьДокумент()


Функция бит_омни_ЗаявкиПоПациенту(ИдентификаторПациента) Экспорт
	
	Если ИдентификаторПациента = Неопределено Тогда
		Возврат Справочники.Клиенты.бит_омни_НеопределенИдентификатор();
	КонецЕсли;	                                                        
	
	Клиент = Справочники.Клиенты.бит_омни_ПациентПоUUID(ИдентификаторПациента, Истина);
	
	Если ТипЗнч(Клиент) <> Тип("СправочникСсылка.Клиенты") Тогда
		Возврат Клиент; // функция может вернуть только HTTPСервисОтвет или СправочникСсылка.Клиенты
	КонецЕсли;
	
	ПараметрыПоиска = Новый Структура();
	ПараметрыПоиска.Вставить("Клиент", Клиент);
	ПараметрыПоиска.Вставить("ТекущаяДата", ТекущаяДатаСеанса());
	ПараметрыПоиска.Вставить("СостояниеОтмена", Справочники.ВидыСостоянийЗаявок.Отменена);
	
	УсловиеПоиска = "
	|	НЕ ЗаявкаРаботы.Ссылка.ПометкаУдаления
	|	И ЗаявкаРаботы.Ссылка.Состояние <> &СостояниеОтмена
	|	И ЗаявкаРаботы.Ссылка.Состояние.ТипСостояния <> ЗНАЧЕНИЕ(Перечисление.ТипыСостоянийЗаявок.Отменена)
	|	И ЗаявкаРаботы.Ссылка.Клиент = &Клиент
	|	И ЗаявкаРаботы.Ссылка.ДатаНачала >= НАЧАЛОПЕРИОДА(&ТекущаяДата, ДЕНЬ)";
	ДанныеИзЗапроса = бит_омни_ПолучитьДанныеЗаявок(ПараметрыПоиска, УсловиеПоиска, 100);
	
	ТелоЗапроса = ОбщегоНазначения.ТаблицаЗначенийВМассив(ДанныеИзЗапроса);
	Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(ТелоЗапроса);

КонецФункции

Функция бит_омни_ЗаявкаПоUUID(Знач ИдентификаторДокумента, ВернутьСсылку = Ложь) Экспорт
	
	РезультатПроверки = бит_омни_ИнтеграцияСервер.ВалидироватьИдентификатор(ИдентификаторДокумента, "appointmentId");
	
	Если РезультатПроверки <> Неопределено Тогда
		Возврат РезультатПроверки;
	КонецЕсли;
	
	Заявка = ПолучитьСсылку(ИдентификаторДокумента);
	Если НЕ ОбщегоНазначения.СсылкаСуществует(Заявка) Тогда
		Возврат бит_омни_НеНайденаЗаявка();
	КонецЕсли;
	
	Если ВернутьСсылку Тогда
		Возврат Заявка;
	КонецЕсли;
	
	ПараметрыПоиска = Новый Структура();
	ПараметрыПоиска.Вставить("Ссылка", Заявка);
	
	УсловиеПоиска = "
	|	ЗаявкаРаботы.Ссылка = &Ссылка";
	ДанныеИзЗапроса = бит_омни_ПолучитьДанныеЗаявок(ПараметрыПоиска, УсловиеПоиска, 1);
	
	ТелоЗапроса = ОбщегоНазначения.ТаблицаЗначенийВМассив(ДанныеИзЗапроса);	
	Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(ТелоЗапроса.Получить(0));

КонецФункции


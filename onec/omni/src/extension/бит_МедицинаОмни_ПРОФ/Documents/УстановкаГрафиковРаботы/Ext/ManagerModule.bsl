Функция бит_омни_ДанныеДокументов(HTTPЗапрос) Экспорт
	
	ИдентификаторСотрудника = HTTPЗапрос.ПараметрыЗапроса.Получить("doctorId");
	ИдентификаторФилиала = HTTPЗапрос.ПараметрыЗапроса.Получить("branchId");
	ДатаЗаписи = HTTPЗапрос.ПараметрыЗапроса.Получить("date");
	Формат = HTTPЗапрос.ПараметрыЗапроса.Получить("format");
	
	Если Формат = Неопределено Тогда
		Возврат НеопределенФормат();
	ИначеЕсли Формат = "OnlyDate" Тогда
		Возврат бит_омни_ДатыРасписания(ИдентификаторСотрудника, ИдентификаторФилиала);		
	ИначеЕсли Формат = "Full" Тогда
		Возврат бит_омни_РасписаниеНаДень(ИдентификаторСотрудника, ИдентификаторФилиала, ДатаЗаписи);
	Иначе
		Возврат НеверныйФормат();
	КонецЕсли;

КонецФункции      

Функция НеопределенФормат()

	Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой("format_required");

КонецФункции

Функция НеверныйФормат()

	Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой("invalid_format");

КонецФункции

Функция бит_омни_ДатыРасписания(ИдентификаторСотрудника, ИдентификаторФилиала)

	Сотрудник = Справочники.Сотрудники.бит_омни_СотрудникПоUUID(ИдентификаторСотрудника, Истина);
	
	Если ТипЗнч(Сотрудник) <> Тип("СправочникСсылка.Сотрудники") Тогда
		Возврат Сотрудник; // если тип другой, то это HTTPСервисОтвет
	КонецЕсли;
	
	Филиал = Справочники.Филиалы.бит_омни_ФилиалПоUUID(ИдентификаторФилиала, Истина);
	
	Если ТипЗнч(Филиал) <> Тип("СправочникСсылка.Филиалы") Тогда
		Возврат Филиал; // если тип другой, то это HTTPСервисОтвет
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ГрафикиРаботы.Дата КАК Дата
	|ИЗ
	|	РегистрСведений.ГрафикиРаботы КАК ГрафикиРаботы
	|ГДЕ
	|	ГрафикиРаботы.Сотрудник = &Сотрудник
	|	И ГрафикиРаботы.Филиал = &Филиал
	|	И ГрафикиРаботы.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
	|	И ГрафикиРаботы.ВидВремени В(&ВыгружаемыеВидыВремени)";
	
	Сегодня = НачалоДня(ТекущаяДата());
	Запрос.УстановитьПараметр("ВыгружаемыеВидыВремени",  бит_омни_ВыгружаемыеВидыВремени());
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("Филиал", Филиал);
	Запрос.УстановитьПараметр("ДатаНачала", Сегодня);
	Запрос.УстановитьПараметр("ДатаОкончания", ДобавитьМесяц(Сегодня, 1)); 
	
	РезультатЗапроса = Запрос.Выполнить();
	ДанныеЗапроса = РезультатЗапроса.Выгрузить();
	
	ТелоОтвета = ДанныеЗапроса.ВыгрузитьКолонку("Дата");
	Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(ТелоОтвета);

КонецФункции

Функция бит_омни_РасписаниеНаДень(ИдентификаторСотрудника, ИдентификаторФилиала, ДатаЗаписи)

	Сотрудник = Справочники.Сотрудники.бит_омни_СотрудникПоUUID(ИдентификаторСотрудника, Истина);
	
	Если ТипЗнч(Сотрудник) <> Тип("СправочникСсылка.Сотрудники") Тогда
		Возврат Сотрудник; // если тип другой, то это HTTPСервисОтвет
	КонецЕсли;
	
	Филиал = Справочники.Филиалы.бит_омни_ФилиалПоUUID(ИдентификаторФилиала, Истина);
	
	Если ТипЗнч(Филиал) <> Тип("СправочникСсылка.Филиалы") Тогда
		Возврат Филиал; // если тип другой, то это HTTPСервисОтвет
	КонецЕсли;
	
	РезультатПроверки = бит_омни_ИнтеграцияСервер.ВалидироватьДату(ДатаЗаписи, "date");
	
	Если РезультатПроверки <> Неопределено Тогда
		Возврат РезультатПроверки;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Графики.Сотрудник КАК Сотрудник,
	|	Графики.Дата КАК Дата,
	|	Графики.ВремяНачала КАК ВремяНачала,
	|	Графики.ВремяОкончания КАК ВремяОкончания,
	|	Графики.ВидВремени КАК ВидВремени,
	|	Графики.Филиал КАК Филиал,
	|	Графики.Кабинет КАК Кабинет,
	|	Графики.ВидВремени В (&ВыгружаемыеВидыВремени) КАК ЭтоРабочееВремя,
	|	NULL КАК ЗаявкаСсылка
	|ПОМЕСТИТЬ ВтГрафикиРаботы
	|ИЗ
	|	РегистрСведений.ГрафикиРаботы КАК Графики
	|ГДЕ
	|	Графики.Дата = &ДатаЗаписи
	|	И Графики.Сотрудник = &Сотрудник
	|	И Графики.Филиал = &Филиал
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА ЗаявкаРаботы.Сотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|			ТОГДА Заявка.Сотрудник
	|		ИНАЧЕ ЗаявкаРаботы.Сотрудник
	|	КОНЕЦ КАК Сотрудник,
	|	НАЧАЛОПЕРИОДА(Заявка.ДатаНачала, ДЕНЬ) КАК Дата,
	|	ЗаявкаРаботы.ДатаНачала КАК ВремяНачала,
	|	ЗаявкаРаботы.ДатаОкончания КАК ВремяОкончания,
	|	НЕОПРЕДЕЛЕНО КАК ВидВремени,
	|	Заявка.Филиал КАК Филиал,
	|	ВЫБОР
	|		КОГДА ЗаявкаРаботы.Оборудование1 = ЗНАЧЕНИЕ(Справочник.Оборудование.ПустаяСсылка)
	|			ТОГДА Заявка.Кабинет
	|		ИНАЧЕ ЗаявкаРаботы.Оборудование1
	|	КОНЕЦ КАК Кабинет,
	|	ЛОЖЬ КАК ЭтоРабочееВремя,
	|	Заявка.Ссылка КАК ЗаявкаСсылка
	|ПОМЕСТИТЬ ВтЗаявки
	|ИЗ
	|	Документ.Заявка КАК Заявка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Заявка.Работы КАК ЗаявкаРаботы
	|		ПО Заявка.Ссылка = ЗаявкаРаботы.Ссылка
	|ГДЕ
	|	НАЧАЛОПЕРИОДА(Заявка.ДатаНачала, ДЕНЬ) = &ДатаЗаписи
	|	И НЕ Заявка.ПометкаУдаления
	|	И Заявка.Состояние <> ЗНАЧЕНИЕ(Справочник.ВидыСостоянийЗаявок.Отменена)
	|	И (ЗаявкаРаботы.Сотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
	|				И Заявка.Сотрудник = &Сотрудник
	|			ИЛИ ЗаявкаРаботы.Сотрудник = &Сотрудник)
	|	И Заявка.Филиал = &Филиал
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Графики.ВремяНачала КАК time_begin,
	|	Графики.ВремяОкончания КАК time_end,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Графики.Кабинет)) КАК cabinetId,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Графики.Кабинет) КАК cabinetTitle,
	|	Графики.ЭтоРабочееВремя КАК isWorkTime,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ЗНАЧЕНИЕ(Документ.Заявка.ПустаяСсылка))) КАК appointmentId
	|ИЗ
	|	ВтГрафикиРаботы КАК Графики
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Заявки.ВремяНачала,
	|	Заявки.ВремяОкончания,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Заявки.Кабинет)),
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Заявки.Кабинет),
	|	Заявки.ЭтоРабочееВремя,
	|	ПРЕДСТАВЛЕНИЕ(УНИКАЛЬНЫЙИДЕНТИФИКАТОР(Заявки.ЗаявкаСсылка))
	|ИЗ
	|	ВтЗаявки КАК Заявки
	|
	|УПОРЯДОЧИТЬ ПО
	|	time_begin,
	|	time_end";
	
	Запрос.УстановитьПараметр("ВыгружаемыеВидыВремени",  бит_омни_ВыгружаемыеВидыВремени());
	Запрос.УстановитьПараметр("ДатаЗаписи",  ДатаЗаписи);
	Запрос.УстановитьПараметр("Сотрудник",  Сотрудник);
	Запрос.УстановитьПараметр("Филиал",  Филиал);
	
	РезультатЗапроса = Запрос.Выполнить();
	ДанныеЗапроса = РезультатЗапроса.Выгрузить();
	
	ТелоОтвета = ОбщегоНазначения.ТаблицаЗначенийВМассив(ДанныеЗапроса);
	
	Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(ТелоОтвета);
	
КонецФункции


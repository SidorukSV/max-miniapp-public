// Обрабатывает GET-запросы к каталогам
Функция CatalogsGET(Запрос)
	
	КлючОбъекта = Запрос.ПараметрыURL.Получить("key");
	МенеджерСправочника = бит_омни_ИнтеграцияПовтИсп.ПолучитьМенеджераПоКлючу("catalog" ,КлючОбъекта);
	
	Возврат ВыполнитьБезопасныйВызов(
		МенеджерСправочника,
		"бит_омни_ДанныеСправочника",
		"invalid_catalog_id",
		Запрос);
	
КонецФункции


// Возвращает настройки приложения.
Функция SettingsGET(Запрос)
	
	Попытка
		
		ЗначенияНастроек = бит_омни_ОбщегоНазначенияПолныеПрава.ЗначенияКонстант(
			"ВыводитьБонусы, ВыводитьАнкеты");
		
		ВидимостьСтраниц = Новый Структура;
		ВидимостьСтраниц.Вставить(
			"bonuses",
			ЗначенияНастроек.Получить("ВыводитьБонусы"));
		ВидимостьСтраниц.Вставить(
			"survey",
			ЗначенияНастроек.Получить("ВыводитьАнкеты"));
		
		Настройки = Новый Структура;
		Настройки.Вставить("visibility_pages", ВидимостьСтраниц);
		
		Возврат бит_омни_ИнтеграцияСервер.УспешныйОтвет(Настройки);
		
	Исключение
		
		ИнфоОшибки = ИнформацияОбОшибке();
		ТекстОшибки = ПодробноеПредставлениеОшибки(ИнфоОшибки);
		
		ЗаписьЖурналаРегистрации(
			"ОМНИ.Ошибка",
			УровеньЖурналаРегистрации.Ошибка,
			,,
			СтрШаблон("Ошибка получения настроек приложения: %1", ТекстОшибки));
		
		Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой(
			"settings_unavailable",
			500,
			ТекстОшибки);
		
	КонецПопытки;
	
КонецФункции

Функция MAXWebhookPOST(Запрос)
	
	ИдентификаторБота = Запрос.ПараметрыURL.Получить("bot");
	Бот = бит_омни_ИнтеграцияСMAXПовтИсп.БотПоИдентификатору(ИдентификаторБота);
	
	Если Бот = Неопределено Тогда
		Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой("max_bot_not_found", 404);
	КонецЕсли;
	
	Возврат бит_омни_ИнтеграцияСMAX.ОбработатьWebhook(Запрос, Бот);
	
КонецФункции

// Внутренняя функция для безопасного вызова методов менеджеров с обработкой ошибок
Функция ВыполнитьБезопасныйВызов(Менеджер, ИмяМетода, КодОшибки, Запрос)
	
	Если Менеджер = Неопределено Тогда
		Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой(КодОшибки);
	КонецЕсли;
	
	Попытка
		Возврат Вычислить(СтрШаблон("Менеджер.%1(Запрос)", ИмяМетода));
	Исключение
		ИнфоОшибки = ИнформацияОбОшибке();
		ТекстОшибки = ПодробноеПредставлениеОшибки(ИнфоОшибки);
		
		// Логируем ошибку
		ЗаписьЖурналаРегистрации(
			"ОМНИ.Ошибка",
			УровеньЖурналаРегистрации.Ошибка,
			,,
			СтрШаблон("Ошибка при вызове %1: %2", ИмяМетода, ТекстОшибки));
		
		Возврат бит_омни_ИнтеграцияСервер.ОтветСОшибкой(ТекстОшибки, 500);
	КонецПопытки;
	
КонецФункции

